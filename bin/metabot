codex_path = env("CODEX_EXECUTABLE_PATH") or shutil.which("codex")
codex_home = Path(env("CODEX_HOME", str(Path.home() / ".codex"))).expanduser()
codex_config = codex_home / "config.toml"

def parse_codex_feature_list(output):
    features = {}
    for raw in output.splitlines():
        line = raw.strip()
        if not line or line.startswith("Usage:") or line.startswith("Commands:"):
            continue
        parts = line.split()
        if len(parts) < 3 or parts[-1] not in ("true", "false"):
            continue
        name = parts[0]
        stage = " ".join(parts[1:-1])
        features[name] = {"stage": stage, "enabled": parts[-1] == "true"}
    return features

def count_codex_mcp_servers(config_path):
    if not config_path.exists():
        return 0
    count = 0
    for raw in config_path.read_text(errors="ignore").splitlines():
        if raw.strip().startswith("[mcp_servers."):
            count += 1
    return count

codex_data = {
    "executable": codex_path,
    "hasOpenAIKey": bool(env("OPENAI_API_KEY")),
    "hasCodexApiKey": bool(env("CODEX_API_KEY")),
    "baseUrl": env("CODEX_BASE_URL") or env("OPENAI_BASE_URL"),
    "model": env("CODEX_MODEL"),
    "codexHome": str(codex_home),
    "configTomlExists": codex_config.exists(),
    "skillsDirExists": (codex_home / "skills").is_dir(),
    "agentsDirExists": (codex_home / "agents").is_dir(),
    "memoriesDirExists": (codex_home / "memories").is_dir(),
    "memoryDbExists": bool(list(codex_home.glob("memories_*.sqlite"))),
    "mcpServerCount": count_codex_mcp_servers(codex_config),
}
codex_ok = bool(codex_path)
if codex_path:
    v = run([codex_path, "--version"], timeout=3)
    codex_data["versionOk"] = v["ok"]
    codex_data["version"] = v["stdout"] or v["stderr"]
    features_result = run([codex_path, "features", "list"], timeout=5)
    codex_data["featuresListOk"] = features_result["ok"]
    if features_result["ok"]:
        features = parse_codex_feature_list(features_result["stdout"])
        important_features = [
            "multi_agent",
            "memories",
            "plugins",
            "hooks",
            "browser_use",
            "computer_use",
            "image_generation",
            "guardian_approval",
            "prevent_idle_sleep",
        ]
        codex_data["features"] = {name: features.get(name) for name in important_features if name in features}
check("codex_cli", codex_ok, "codex_missing" if not codex_ok else "ok",
      "Codex executable found." if codex_ok else "Codex executable not found.",
      "Install Codex CLI or set CODEX_EXECUTABLE_PATH.",
      False,
      codex_data)

codex_features = codex_data.get("features", {})
required_codex_features = ["multi_agent", "memories"]
missing_codex_features = [
    name for name in required_codex_features
    if not codex_features.get(name, {}).get("enabled")
]
codex_agent_features_ok = bool(codex_path) and not missing_codex_features and codex_data["skillsDirExists"] and (codex_data["memoriesDirExists"] or codex_data["memoryDbExists"])
check("codex_agent_features", codex_agent_features_ok,
      "codex_agent_features_missing" if not codex_agent_features_ok else "ok",
      "Codex multi-agent, memories, skills, and memory storage are ready." if codex_agent_features_ok else "Codex agent features are missing or disabled.",
      "Run install.sh with Codex selected, or add [features] multi_agent=true and memories=true to ~/.codex/config.toml; ensure ~/.codex/skills and ~/.codex/memories exist.",
      False,
      {
          "requiredFeatures": required_codex_features,
          "missingFeatures": missing_codex_features,
          "skillsDirExists": codex_data["skillsDirExists"],
          "agentsDirExists": codex_data["agentsDirExists"],
          "memoriesDirExists": codex_data["memoriesDirExists"],
          "memoryDbExists": codex_data["memoryDbExists"],
          "mcpServerCount": codex_data["mcpServerCount"],
      })

bwrap_path = shutil.which("bwrap")
bwrap_version = run([bwrap_path, "--version"], timeout=3) if bwrap_path else {"ok": False, "stdout": "", "stderr": "bwrap not found"}
unshare_path = shutil.which("unshare")
unshare_user = run([unshare_path, "-Ur", "true"], timeout=3) if unshare_path else {"ok": False, "stdout": "", "stderr": "unshare not found"}
bwrap_smoke = run([
    bwrap_path,
    "--unshare-user",
    "--uid", "0",
    "--gid", "0",
    "--ro-bind", "/", "/",
    "--proc", "/proc",
    "--dev", "/dev",
    "--tmpfs", "/tmp",
    "/bin/sh", "-lc", "true",
], timeout=5) if bwrap_path else {"ok": False, "stdout": "", "stderr": "bwrap not found"}
cap_eff = proc_status_value("CapEff")
try:
    has_cap_sys_admin = bool(int(cap_eff or "0", 16) & (1 << 21))
except Exception:
    has_cap_sys_admin = None
# bwrap file permissions: mode octal string, setuid bit, and Linux capabilities via getcap
bwrap_filemode = None
bwrap_setuid = None
if bwrap_path:
    try:
        st = os.stat(bwrap_path)
        bwrap_filemode = oct(st.st_mode)
        bwrap_setuid = bool(st.st_mode & 0o4000)
    except Exception:
        pass
getcap_path = shutil.which("getcap")
bwrap_capabilities = None
if bwrap_path and getcap_path:
    _gc = run([getcap_path, bwrap_path], timeout=3)
    bwrap_capabilities = (_gc["stdout"] or _gc["stderr"] or "").strip() or None
codex_sandbox_data = {
    "bwrap": bwrap_path,
    "bwrapVersion": bwrap_version["stdout"] or bwrap_version["stderr"],
    "bwrapSmokeOk": bwrap_smoke["ok"],
    "bwrapSmokeStderr": bwrap_smoke["stderr"][:500],
    "bwrapFileMode": bwrap_filemode,
    "bwrapSetuid": bwrap_setuid,
    "bwrapCapabilities": bwrap_capabilities,
    "unshare": unshare_path,
    "unshareUserOk": unshare_user["ok"],
    "unshareUserStderr": unshare_user["stderr"][:500],
    "kernelUnprivilegedUsernsClone": read_text("/proc/sys/kernel/unprivileged_userns_clone"),
    "userMaxUserNamespaces": read_text("/proc/sys/user/max_user_namespaces"),
    "seccomp": proc_status_value("Seccomp"),
    "apparmor": read_text("/proc/self/attr/current"),
    "cgroup": read_text("/proc/1/cgroup"),
    "capEff": cap_eff,
    "hasCapSysAdmin": has_cap_sys_admin,
}
check("codex_sandbox_namespaces", bwrap_smoke["ok"],
      "ok" if bwrap_smoke["ok"] else ("bwrap_missing" if not bwrap_path else "bwrap_namespace_unavailable"),
      "Codex read-only/workspace-write sandbox namespaces are available." if bwrap_smoke["ok"] else "Codex read-only/workspace-write sandbox namespaces are not available on this host/container.",
      "Use Codex danger-full-access/bypass for this runtime, or run the container/host with user namespaces allowed by seccomp/AppArmor and kernel policy, then re-run metabot doctor --json.",
      False,
      codex_sandbox_data)

team_base = None
for candidate in (env("CODEX_BASE_URL"), env("OPENAI_BASE_URL"), env("ANTHROPIC_BASE_URL")):
    if candidate and "teamclaude" in candidate:
        team_base = candidate.split("/openai/")[0].rstrip("/")
        break
team_token = env("OPENAI_API_KEY") or env("CODEX_API_KEY") or env("ANTHROPIC_AUTH_TOKEN") or env("ANTHROPIC_API_KEY")
team_data = {"baseUrl": team_base, "tokenPresent": bool(team_token)}
team_ok = bool(team_base and team_token)
if team_ok:
    me = http_json(f"{team_base}/api/me", team_token)
    team_data.update({"meStatus": me["status"], "me": me["json"] or me["bodyPreview"]})
    if me["status"] in (401, 403):
        team_ok = False
check("teamclaude", team_ok, "teamclaude_not_configured_or_invalid" if not team_ok else "ok",
      "TeamClaude endpoint/token appear configured." if team_ok else "TeamClaude endpoint/token not configured or token check failed.",
      "Set TeamClaude base URL and token, then verify token owner before assigning to bots.",
      False,
      team_data)

report["ok"] = all(c.get("ok") for c in checks if c["name"] in ("metabot_home", "pm2_runtime", "bridge_health"))
report["summary"] = {
    "ok": sum(1 for c in checks if c["ok"]),
    "warn": sum(1 for c in checks if not c["ok"]),
    "criticalOk": report["ok"],
}

if want_json:
    print(json.dumps(report, ensure_ascii=False, indent=2))
else:
    print(f"MetaBot doctor: {'OK' if report['ok'] else 'WARN'}")
    print(f"  METABOT_HOME: {home}")
    for c in checks:
        mark = "✓" if c["ok"] else "!"
        print(f"  {mark} {c['name']}: {c['code']}")
        if not c["ok"] and c["recommendedAction"]:
            print(f"    next: {c['recommendedAction']}")
    print("\nUse `metabot doctor --json` for agent-readable diagnostics.")
PY
}

# Resolve the metabot-core feature CLI (t5t/agents/memory/skills).
# A source-tree launcher is usable only when its dist entry exists. This matters
# when the bridge runs from a Git worktree that intentionally has not been built.
_expand_user_path() {
  local value="$1"
  case "$value" in
    "~"|"~/"*) printf '%s\n' "${HOME}${value#\~}" ;;
    *) printf '%s\n' "$value" ;;
  esac
}

_canonical_existing_path() {
  local path_value
  path_value="$(_expand_user_path "$1")"
  if [[ -e "$path_value" || -L "$path_value" ]]; then
    if command -v readlink &>/dev/null; then
      readlink -f "$path_value" 2>/dev/null || printf '%s\n' "$path_value"
    else
      printf '%s\n' "$path_value"
    fi
  else
    printf '%s\n' "$path_value"
  fi
}

_core_cli_is_ready() {
  local candidate="$1"
  local expanded
  expanded="$(_expand_user_path "$candidate")"
  [[ -f "$expanded" ]] || return 1
  local resolved
  resolved="$(_canonical_existing_path "$expanded")"
  case "$resolved" in
    */packages/cli/bin/metabot)
      local package_root="${resolved%/bin/metabot}"
      [[ -f "$package_root/dist/index.js" ]] || return 1
      ;;
  esac
  return 0
}

_core_cli_default_config_root() {
  local default_env="${METABOT_DEFAULT_ENV_FILE:-}"
  if [[ -n "$default_env" ]]; then
    default_env="$(_canonical_existing_path "$default_env")"
    dirname "$default_env"
  fi
  return 0
}

# Order: explicit override > ready in-tree CLI > ready default-config checkout
# > ready stable checkout > sibling workspace > npm-global on PATH.
_resolve_core_cli() {
  local core_cli_candidates=()
  local candidate
  _append_core_cli_candidate() {
    candidate="$1"
    [[ -n "$candidate" ]] || return 0
    candidate="$(_canonical_existing_path "$candidate")"
    local existing
    for existing in "${core_cli_candidates[@]}"; do
      [[ "$existing" == "$candidate" ]] && return 0
    done
    core_cli_candidates+=("$candidate")
  }
  if [[ -n "${METABOT_CORE_CLI:-}" ]]; then
    local explicit_core_cli
    explicit_core_cli="$(_canonical_existing_path "$METABOT_CORE_CLI")"
    if _core_cli_is_ready "$explicit_core_cli"; then
      echo "$explicit_core_cli"; return 0
    fi
    echo "Explicit METABOT_CORE_CLI is not runnable or does not have a built dist entry: $METABOT_CORE_CLI (resolved: $explicit_core_cli)" >&2
    return 2
  fi
  # In-tree (monorepo): packages/cli is shipped alongside this script.
  local intree="$METABOT_HOME/packages/cli/bin/metabot"
  _append_core_cli_candidate "$intree"
  # Worktree deployments commonly share an env/config file with a stable,
  # already-built checkout. Use its CLI code without deriving backend config
  # from that code path.
  local config_root
  config_root="$(_core_cli_default_config_root)"
  local config_cli="${config_root:+$config_root/packages/cli/bin/metabot}"
  _append_core_cli_candidate "$config_cli"
  local stable="$HOME/metabot/packages/cli/bin/metabot"
  _append_core_cli_candidate "$stable"
  # Sibling workspace (legacy two-repo layout — kept during migration).
  local ws="$METABOT_HOME/../metabot-workspace/metabot-core/packages/cli/bin/metabot"
  _append_core_cli_candidate "$ws"
  # npm-linked global: a `metabot-core` bin on PATH (NOT this script).
  local g
  g="$(command -v metabot-core 2>/dev/null || true)"
  _append_core_cli_candidate "$g"
  for candidate in "${core_cli_candidates[@]}"; do
    if _core_cli_is_ready "$candidate"; then
      echo "$candidate"; return 0
    fi
  done
  return 1
}

_load_core_cli_config() {
  # Keep code resolution separate from backend selection. Explicit process env
  # wins; otherwise worktree .env overrides the shared default env file.
  local default_env="${METABOT_DEFAULT_ENV_FILE:-}"
  default_env="$(_expand_user_path "$default_env")"
  local worktree_env="$METABOT_HOME/.env"
  local k
  for k in METABOT_CORE_URL METABOT_CORE_TOKEN; do
    [[ -n "${!k:-}" ]] && continue
    local value=""
    local envf
    for envf in "$default_env" "$worktree_env"; do
      [[ -n "$envf" && -f "$envf" ]] || continue
      local line
      line="$(grep -E "^${k}=" "$envf" | tail -n1 || true)"
      if [[ -n "$line" ]]; then
        value="$(printf '%s' "${line#${k}=}" | sed -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'\$//")"
      fi
    done
    [[ -n "$value" ]] && export "${k}=$value"
  done
  return 0
}

cmd_delegate() {
  local core_cli
  if ! core_cli="$(_resolve_core_cli)"; then
    error "'metabot $1' needs the metabot-core CLI, which isn't installed here." >&2
    echo "  Fix one of:" >&2
    echo "    - Build the in-tree CLI: cd \"$METABOT_HOME\" && npm ci && npm run build -w @xvirobotics/cli" >&2
    echo "    - Or set METABOT_DEFAULT_ENV_FILE to the .env of a ready checkout." >&2
    echo "    - Or point at it:        export METABOT_CORE_CLI=/path/to/packages/cli/bin/metabot" >&2
    exit 1
  fi
  _load_core_cli_config
  exec node "$core_cli" "$@"
}

# --- Category 2: bridge daemon API (curls the local bridge at localhost:9100) ---
cmd_bridge_api() {
  _load_bridge_api_config
  local cmd="$1"; shift 2>/dev/null || true
  case "$cmd" in
    bots|b)
      curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/bots" | _json
      ;;
    bot)
      curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/bots/$1" | _json
      ;;
    talk|t)
      local async=false send_cards=true wait_ms="${METABOT_TALK_WAIT_MS:-25000}" wait_ms_set=false
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --async)
            async=true
            if [[ "$wait_ms_set" != true ]]; then wait_ms=""; fi
            shift ;;
          --sync)
            async=false; wait_ms=""; wait_ms_set=true; shift ;;
          --no-cards)
            send_cards=false; shift ;;
          --wait-ms)
            wait_ms="${2:-}"; wait_ms_set=true; shift 2 ;;
          --)
            shift; break ;;
          -*)
            echo "Unknown metabot talk option: $1" >&2
            echo "Usage: metabot talk [--async|--sync] [--no-cards] [--wait-ms N] [peer/]<botName> <chatId> <prompt>" >&2
            exit 1 ;;
          *)
            break ;;
        esac
      done
      local bot="${1:-}" chat="${2:-}"
      if [[ $# -ge 2 ]]; then shift 2; fi
      local prompt="$*"
      if [[ -z "${bot:-}" || -z "${chat:-}" || -z "${prompt:-}" ]]; then
        echo "Usage: metabot talk [--async|--sync] [--no-cards] [--wait-ms N] [peer/]<botName> <chatId> <prompt>"
        echo "  Examples:"
        echo "    metabot talk mybot chat123 'fix the bug'"
        echo "    metabot talk --sync mybot chat123 'wait until complete'"
        echo "    metabot talk --async --no-cards mybot private-chat 'run privately'"
        echo "    metabot talk --wait-ms 25000 mybot chat123 'return fast or give me a task id'"
        echo "    metabot talk alice/backend-bot chat123 'deploy to staging'"
        exit 1
      fi
      python3 -c "
import json, sys
payload = {'botName': sys.argv[1], 'chatId': sys.argv[2], 'prompt': sys.argv[3], 'sendCards': sys.argv[4] == 'true'}
if sys.argv[5] == 'true':
    payload['async'] = True
if sys.argv[6]:
    payload['waitMs'] = int(sys.argv[6])
print(json.dumps(payload))
" "$bot" "$chat" "$prompt" "$send_cards" "$async" "$wait_ms" | \
      curl -s -X POST "$METABOT_URL/api/talk" \
        -H "$METABOT_AUTH" -H "Content-Type: application/json" \
        -d @-
      ;;
    talk-status|ts)
      local task_id="${1:-}"
      if [[ -z "$task_id" ]]; then
        echo "Usage: metabot talk-status <taskId>"
        exit 1
      fi
      curl -s --connect-timeout 10 --max-time 30 \
        -H "$METABOT_AUTH" "$METABOT_URL/api/talk/$task_id" | _json
      ;;
    schedule|sched|sc)
      local subcmd="${1:-list}"; shift 2>/dev/null || true
      case "$subcmd" in
        list|ls)
          curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/schedule" | _json
          ;;
        add|a)
          local bot="$1" chat="$2" delay="$3"; shift 3 2>/dev/null || true
          local prompt="$*"
          if [[ -z "${bot:-}" || -z "${chat:-}" || -z "${delay:-}" || -z "${prompt:-}" ]]; then
            echo "Usage: metabot schedule add <botName> <chatId> <delaySeconds> <prompt>"
            exit 1
          fi
          python3 -c "
import json, sys
print(json.dumps({'botName': sys.argv[1], 'chatId': sys.argv[2], 'delaySeconds': int(sys.argv[3]), 'prompt': sys.argv[4]}))
" "$bot" "$chat" "$delay" "$prompt" | \
          curl -s -X POST "$METABOT_URL/api/schedule" \
            -H "$METABOT_AUTH" -H "Content-Type: application/json" \
            -d @- | _json
          ;;
        cron|c)
          local bot="$1" chat="$2" cron_expr="$3"; shift 3 2>/dev/null || true
          local prompt="$*"
          if [[ -z "${bot:-}" || -z "${chat:-}" || -z "${cron_expr:-}" || -z "${prompt:-}" ]]; then
            echo "Usage: metabot schedule cron <botName> <chatId> '<cronExpr>' <prompt>"
            echo "  Example: metabot schedule cron mybot oc_xxx '0 8 * * 1-5' Generate daily report"
            exit 1
          fi
          python3 -c "
import json, sys
print(json.dumps({'botName': sys.argv[1], 'chatId': sys.argv[2], 'cronExpr': sys.argv[3], 'prompt': sys.argv[4]}))
" "$bot" "$chat" "$cron_expr" "$prompt" | \
          curl -s -X POST "$METABOT_URL/api/schedule" \
            -H "$METABOT_AUTH" -H "Content-Type: application/json" \
            -d @- | _json
          ;;
        pause|p)
          if [[ -z "${1:-}" ]]; then echo "Usage: metabot schedule pause <id>"; exit 1; fi
          curl -s -X POST "$METABOT_URL/api/schedule/$1/pause" -H "$METABOT_AUTH" | _json
          ;;
        resume|r)
          if [[ -z "${1:-}" ]]; then echo "Usage: metabot schedule resume <id>"; exit 1; fi
          curl -s -X POST "$METABOT_URL/api/schedule/$1/resume" -H "$METABOT_AUTH" | _json
          ;;
        cancel|rm)
          if [[ -z "${1:-}" ]]; then echo "Usage: metabot schedule cancel <id>"; exit 1; fi
          curl -s -X DELETE "$METABOT_URL/api/schedule/$1" -H "$METABOT_AUTH" | _json
          ;;
        *)
          echo "metabot schedule - Task scheduling"
          echo "  metabot schedule list                                    - List all scheduled tasks"
          echo "  metabot schedule add <bot> <chatId> <delaySec> <prompt>  - Schedule a one-time task"
          echo "  metabot schedule cron <bot> <chatId> '<cron>' <prompt>   - Schedule a recurring task"
          echo "  metabot schedule pause <id>                              - Pause a recurring task"
          echo "  metabot schedule resume <id>                             - Resume a paused task"
          echo "  metabot schedule cancel <id>                             - Cancel a task"
          ;;
      esac
      ;;
    peers|p)
      local subcmd="${1:-list}"; shift 2>/dev/null || true
      case "$subcmd" in
        list|ls)
          curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/peers" | _json
          ;;
        add|a)
          local pname="$1" purl="$2" psecret="${3:-}"
          if [[ -z "${pname:-}" || -z "${purl:-}" ]]; then
            echo "Usage: metabot peers add <name> <url> [secret]"
            echo "  Example: metabot peers add alice http://10.0.0.5:9100"
            exit 1
          fi
          python3 -c "
import json, sys
body = {'name': sys.argv[1], 'url': sys.argv[2]}
if len(sys.argv) > 3 and sys.argv[3]:
    body['secret'] = sys.argv[3]
print(json.dumps(body))
" "$pname" "$purl" "$psecret" | \
          curl -s -X POST "$METABOT_URL/api/peers" \
            -H "$METABOT_AUTH" -H "Content-Type: application/json" \
            -d @- | _json
          ;;
        remove|rm|del)
          local pname="$1"
          if [[ -z "${pname:-}" ]]; then
            echo "Usage: metabot peers remove <name>"
            exit 1
          fi
          curl -s -X DELETE -H "$METABOT_AUTH" "$METABOT_URL/api/peers/$pname" | _json
          ;;
        *)
          echo "Usage: metabot peers [list|add|remove]"
          echo "  metabot peers                       - List peers and their status"
          echo "  metabot peers add <name> <url> [secret] - Add a peer at runtime (no restart)"
          echo "  metabot peers remove <name>         - Remove a peer"
          ;;
      esac
      ;;
    stats)
      curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/stats" | _json
      ;;
    metrics|m)
      curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/metrics"
      ;;
    voice|v)
      local subcmd="${1:-help}"; shift 2>/dev/null || true
      case "$subcmd" in
        call|c)
          local bot="${1:-}" chat="${2:-}"; shift 2 2>/dev/null || true
          local _welcome=""
          local _prompt=""
          while [[ $# -gt 0 ]]; do
            case "$1" in
              -w|--welcome) _welcome="$2"; shift 2 ;;
              *)            _prompt="${_prompt:+$_prompt }$1"; shift ;;
            esac
          done
          if [[ -z "${bot:-}" || -z "${chat:-}" ]]; then
            echo "Usage: metabot voice call <botName> <chatId> [prompt] [-w welcomeMessage]"
            echo "  Initiates an RTC voice call. Notifies the web/iOS user,"
            echo "  waits for the call to end, and returns the transcript."
            echo ""
            echo "  Options:"
            echo "    -w, --welcome <text>  AI's opening line (what it says first)"
            echo ""
            echo "  Examples:"
            echo "    metabot voice call whis chat123 'Tell user they are awesome' -w 'Flood, 你是最棒的！'"
            echo "    metabot voice call whis chat123 -w 'Hi! I wanted to discuss the project progress.'"
            exit 1
          fi
          echo "Starting voice call... (waiting for user to join and call to end)"
          python3 -c "
import json, sys
p = {'botName': sys.argv[1], 'chatId': sys.argv[2]}
if sys.argv[3]: p['prompt'] = sys.argv[3]
if sys.argv[4]: p['welcomeMessage'] = sys.argv[4]
print(json.dumps(p))
" "$bot" "$chat" "${_prompt:-}" "${_welcome:-}" | \
          curl -s -X POST "$METABOT_URL/api/rtc/voice?wait=true" \
            -H "$METABOT_AUTH" -H "Content-Type: application/json" \
            --max-time 660 \
            -d @- | _json
          ;;
        transcript|t)
          if [[ -z "${1:-}" ]]; then echo "Usage: metabot voice transcript <sessionId>"; exit 1; fi
          curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/rtc/transcript?sessionId=$1" | _json
          ;;
        list|ls)
          curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/rtc/sessions" | _json
          ;;
        config)
          curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/rtc/config" | _json
          ;;
        tts)
          local _provider=""
          local _voice=""
          local _output=""
          local _play=false
          local _text=""
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --provider|-p) _provider="$2"; shift 2 ;;
              --voice)       _voice="$2"; shift 2 ;;
              -o|--output)   _output="$2"; shift 2 ;;
              --play)        _play=true; shift ;;
              --)            shift; _text="$*"; break ;;
              -*)            echo "Unknown flag: $1"; exit 1 ;;
              *)             _text="$*"; break ;;
            esac
          done
          if [[ -z "$_text" ]]; then
            if [[ -t 0 ]]; then
              echo "Usage: metabot voice tts \"text\" [--play] [-o file.mp3] [--provider doubao|openai|elevenlabs] [--voice <name>]"
              echo "  Or pipe text: echo 'hello' | metabot voice tts"
              exit 1
            fi
            _text="$(cat)"
          fi
          local _json_body
          _json_body=$(python3 -c "
import json, sys
body = {'text': sys.argv[1]}
if sys.argv[2]: body['provider'] = sys.argv[2]
if sys.argv[3]: body['voice'] = sys.argv[3]
print(json.dumps(body))
" "$_text" "$_provider" "$_voice")
          if [[ -z "$_output" ]]; then
            _output="/tmp/metabot-voice-$(date +%s).mp3"
          fi
          local _http_code
          _http_code=$(curl -s -w '%{http_code}' -o "$_output" \
            -X POST "$METABOT_URL/api/tts" \
            -H "$METABOT_AUTH" -H "Content-Type: application/json" \
            -d "$_json_body")
          if [[ "$_http_code" != "200" ]]; then
            echo "Error: TTS request failed (HTTP $_http_code)"
            cat "$_output" 2>/dev/null
            rm -f "$_output"
            exit 1
          fi
          echo "$_output"
          if [[ "$_play" == "true" ]]; then
            if command -v afplay &>/dev/null; then afplay "$_output"
            elif command -v mpv &>/dev/null; then mpv --no-video "$_output" 2>/dev/null
            elif command -v ffplay &>/dev/null; then ffplay -nodisp -autoexit "$_output" 2>/dev/null
            elif command -v play &>/dev/null; then play "$_output" 2>/dev/null
            else echo "(no audio player found — install mpv, ffplay, or sox to use --play)"
            fi
          fi
          ;;
        *)
          echo "metabot voice - Voice tools"
          echo ""
          echo "  RTC Voice Call:"
          echo "    metabot voice call <bot> <chatId> [prompt] [-w opening]  - Start voice call"
          echo "    metabot voice transcript <sessionId>     - Get call transcript"
          echo "    metabot voice list                       - List active voice sessions"
          echo "    metabot voice config                     - Check RTC configuration"
          echo ""
          echo "  Text-to-Speech:"
          echo "    metabot voice tts \"text\" [--play] [-o f]  - Generate MP3 from text"
          echo "    metabot voice tts \"text\" --provider doubao - Use specific TTS provider"
          echo "    echo 'hello' | metabot voice tts           - Read from stdin"
          ;;
      esac
      ;;
    teams|team)
      python3 - "$METABOT_URL" "${_api_secret:-changeme}" "$@" <<'PY'
import json
import sys
import time
import urllib.error
import urllib.parse
import urllib.request

base = sys.argv[1].rstrip("/")
token = sys.argv[2]
argv = sys.argv[3:]

def usage():
    print("""metabot teams - MetaBot Agent Teams
  metabot teams list
  metabot teams create <team> [--description text] [--actor-role admin|user|pm]
  metabot teams delete <team> [--actor-role admin|user|pm]
  metabot teams status <team> [--summary|--plain]
  metabot teams bind <team> <chatId> [--display] [--actor-role admin|user|pm]
  metabot teams start|stop <team> [--actor-role admin|user|pm]
  metabot teams activity <team> [--agent name] [--run-id id] [--task-id id] [--chat chatId] [--source name] [--limit n] [--summary|--plain]
  metabot teams dispatch <team> <agent> <subject> [--description text] [--message text] [--from name] [--plain]
  metabot teams next <team> <agent> [--read] [--summary|--plain]
  metabot teams watch <team> [--interval sec] [--count n] [--summary|--plain]
  metabot teams templates list [name]
  metabot teams templates export <name> [--version n]
  metabot teams templates diff <name> --from n [--to n]
  metabot teams templates import <json> [--source name] [--actor-role admin|user|pm]
  metabot teams proposals list [--status pending|approved|rejected]
  metabot teams proposals create [template|ruleset] <json> [--summary text] [--by name] [--role admin|user|pm|manager|agent]
  metabot teams proposals approve <id> [--by name] [--actor-role admin|user|pm] [--reason text]
  metabot teams proposals reject <id> [--by name] [--actor-role admin|user|pm] [--reason text]
  metabot teams instances list [--template name]
  metabot teams instances resolve <template> [--chat chatId|--project projectId|--global] [--pm-bot name] [--actor-role admin|user|pm]
  metabot teams rules list [name]
  metabot teams rules set <name> --scope scope --rule text [--actor-role admin|user|pm]
  metabot teams rules context --ref name[@version] [--rule text]
  metabot teams agents list <team>
  metabot teams agents spawn <team> <name> [--role r] [--actor-role admin|user|pm] [--engine claude|codex|kimi] [--model m] [--reasoning-effort e] [--approval-policy p] [--sandbox s] [--timeout-ms n] [--idle-timeout-ms n] [--allowed-tools a,b] [--prompt p]
  metabot teams agents stop <team> <name> [--actor-role admin|user|pm]
  metabot teams agents delete <team> <name> [--actor-role admin|user|pm]
  metabot teams send <team> <to> <message> [--from name] [--summary text]
  metabot teams inbox <team> <name> [--unread] [--read] [--summary|--plain]
  metabot teams tasks list <team> [--summary|--plain]
  metabot teams tasks create <team> <subject> [--description text] [--owner name] [--blocked-by id,id]
  metabot teams tasks get <team> <id>
  metabot teams tasks update <team> <id> [--subject s] [--description d] [--status s] [--owner name|none] [--blocked-by id,id] [--result text]
  metabot teams tasks claim <team> <id> [owner|--owner name]
  metabot teams tasks done <team> <id> <result>
  metabot teams tasks block <team> <id> <reason> [--blocked-by id,id]
  metabot teams tasks reopen <team> <id>
  metabot teams runs list <team> [--summary|--plain]
  metabot teams runs create <team> [--agent name] [--task-id id] [--status s] [--output text] [--error text]
  metabot teams runs update <team> <runId> [--status s] [--output text] [--error text]
  metabot teams runs output <team> <runId>
  metabot teams runs stop <team> <runId> [--actor-role admin|user|pm]""")

def parse(args):
    pos, flags, i = [], {}, 0
    while i < len(args):
        a = args[i]
        if a == "--":
            pos.extend(args[i + 1:])
            break
        if a.startswith("--"):
            key = a[2:]
            if "=" in key:
                k, v = key.split("=", 1)
                flags[k] = v
                i += 1
            elif i + 1 < len(args) and not args[i + 1].startswith("-"):
                flags[key] = args[i + 1]
                i += 2
            else:
                flags[key] = True
                i += 1
        else:
            pos.append(a)
            i += 1
    return pos, flags

def actor_role(flags):
    return flags.get("actor-role") or flags.get("as-role") or flags.get("role")

def req_data(method, path, body=None):
    if isinstance(body, dict):
        keep_null = set(body.pop("__keepNull", []))
        body = {k: v for k, v in body.items() if v is not None or k in keep_null}
    data = None if body is None else json.dumps(body).encode()
    headers = {"Authorization": f"Bearer {token}", "Accept": "application/json"}
    if body is not None:
        headers["Content-Type"] = "application/json"
    r = urllib.request.Request(base + path, data=data, headers=headers, method=method)
    try:
        with urllib.request.urlopen(r) as resp:
            text = resp.read().decode()
            try:
                return json.loads(text)
            except Exception:
                return text
    except urllib.error.HTTPError as e:
        sys.stdout.write(e.read().decode() or json.dumps({"error": str(e)}))
        sys.exit(1)

def emit(value):
    if isinstance(value, (dict, list)):
        print(json.dumps(value, indent=2, ensure_ascii=False))
    else:
        text = str(value)
        sys.stdout.write(text)
        if not text.endswith("\n"):
            sys.stdout.write("\n")

def req(method, path, body=None):
    emit(req_data(method, path, body))

def enc(s):
    return urllib.parse.quote(str(s), safe="")

def bool_flag(flags, name):
    return flags.get(name) is True or flags.get(name) in ("true", "1")

def wants_summary(flags):
    return bool_flag(flags, "summary") or bool_flag(flags, "plain")

def parse_number_list(value):
    if not value:
        return None
    nums = []
    for part in str(value).split(","):
        try:
            num = int(part.strip())
        except Exception:
            continue
        if num > 0:
            nums.append(num)
    return nums or None

def array_flag(flags, name):
    value = flags.get(name)
    if not isinstance(value, str):
        return []
    return [part.strip() for part in value.split(",") if part.strip()]

def parse_rule_ref(value):
    name, _, version_raw = value.partition("@")
    ref = {"name": name}
    try:
        version = int(version_raw) if version_raw else None
    except Exception:
        version = None
    if version and version > 0:
        ref["version"] = version
    return ref

def default_agent_name():
    import os
    return os.environ.get("METABOT_TEAM_AGENT") or os.environ.get("METABOT_AGENT_NAME")

def compact(value, limit=120):
    text = " ".join(str(value or "").split())
    return text if len(text) <= limit else text[:max(0, limit - 3)] + "..."

def task_line(task):
    owner = f" @{task.get('owner')}" if task.get("owner") else ""
    blocked = ""
    if task.get("blockedBy"):
        blocked = " blocked_by=" + ",".join(str(x) for x in task.get("blockedBy"))
    result = f" - {compact(task.get('result'), 80)}" if task.get("result") else ""
    return f"#{task.get('id')} {task.get('status')}{owner}{blocked} {task.get('subject')}{result}"

def run_line(run):
    agent = f" @{run.get('agentName')}" if run.get("agentName") else ""
    task = f" task=#{run.get('taskId')}" if run.get("taskId") is not None else ""
    if run.get("error"):
        detail = f" error={compact(run.get('error'), 80)}"
    elif run.get("output"):
        detail = f" output={compact(run.get('output'), 80)}"
    else:
        detail = ""
    return f"{run.get('id')} {run.get('status')}{agent}{task}{detail}"

def format_messages(messages):
    if not messages:
        return ["- none"]
    lines = []
    for message in messages[:12]:
        from_name = f" from {message.get('fromName')}" if message.get("fromName") else ""
        summary = f"{message.get('summary')}: " if message.get("summary") else ""
        lines.append(f"- #{message.get('id')}{from_name} {summary}{compact(message.get('body'), 140)}")
    return lines

def format_tasks(body):
    tasks = body.get("tasks", []) if isinstance(body, dict) else []
    open_tasks = [t for t in tasks if t.get("status") in ("pending", "in_progress")]
    lines = [f"Tasks: {len(tasks)} total, {len(open_tasks)} open"]
    lines.extend(f"- {task_line(task)}" for task in tasks[:20])
    if len(tasks) > 20:
        lines.append(f"... {len(tasks) - 20} more")
    return "\n".join(lines)

def format_runs(body):
    runs = body.get("runs", []) if isinstance(body, dict) else []
    running = len([run for run in runs if run.get("status") == "running"])
    lines = [f"Runs: {len(runs)} total, {running} running"]
    lines.extend(f"- {run_line(run)}" for run in runs[:12])
    if len(runs) > 12:
        lines.append(f"... {len(runs) - 12} more")
    return "\n".join(lines)

def activity_line(item):
    agent = f" @{item.get('agentName')}" if item.get("agentName") else ""
    run = f" run={item.get('runId')}" if item.get("runId") else ""
    tasks = ""
    if item.get("taskIds"):
        tasks = " tasks=#" + ",#".join(str(x) for x in item.get("taskIds"))
    stage = f"/{item.get('lifecycleStage')}" if item.get("lifecycleStage") else ""
    preview = f" - {compact(item.get('responsePreview'), 100)}" if item.get("responsePreview") else ""
    return f"{item.get('lifecycleKey')} {item.get('status')}{stage}{agent}{run}{tasks}{preview}"

def format_activity(body):
    activity = body.get("activity", []) if isinstance(body, dict) else []
    lines = [f"Activity: {len(activity)} records"]
    lines.extend(f"- {activity_line(item)}" for item in activity[:20])
    if len(activity) > 20:
        lines.append(f"... {len(activity) - 20} more")
    return "\n".join(lines)

def format_inbox(body):
    messages = body.get("messages", []) if isinstance(body, dict) else []
    read = f", read {body.get('read')}" if isinstance(body, dict) and isinstance(body.get("read"), int) else ""
    return "\n".join([f"Inbox: {len(messages)} messages{read}", *format_messages(messages)])

def format_next(body):
    unread = body.get("unreadMessages", []) if isinstance(body, dict) else []
    tasks = body.get("assignedTasks", []) if isinstance(body, dict) else []
    read = f" ({body.get('read')} marked read)" if isinstance(body, dict) and body.get("read") else ""
    lines = [
        f"Next: {body.get('team', '?')} / {body.get('agent', '?')}",
        f"Unread: {len(unread)}{read}",
        *format_messages(unread),
        f"Assigned open tasks: {len(tasks)}",
    ]
    lines.extend(f"- {task_line(task)}" for task in tasks[:12])
    if not tasks:
        lines.append("- none")
    return "\n".join(lines)

def format_status(body):
    team = body.get("team", {}) if isinstance(body, dict) else {}
    agents = body.get("agents", []) if isinstance(body, dict) else []
    tasks = body.get("tasks", []) if isinstance(body, dict) else []
    runs = body.get("runs", []) if isinstance(body, dict) else []
    open_tasks = [task for task in tasks if task.get("status") in ("pending", "in_progress")]
    running_runs = [run for run in runs if run.get("status") == "running"]
    agent_text = ", ".join(
        f"{agent.get('name')}:{agent.get('status', 'unknown')}{('/' + agent.get('engine')) if agent.get('engine') else ''}"
        for agent in agents
    )
    lines = [
        f"Team: {team.get('name', '?')} [{team.get('status', '?')}]",
    ]
    if team.get("description"):
        lines.append(compact(team.get("description"), 160))
    lines.append(f"Agents: {len(agents)}" + (f" ({agent_text})" if agent_text else ""))
    lines.append(f"Tasks: {len(tasks)} total, {len(open_tasks)} open")
    lines.extend(f"- {task_line(task)}" for task in open_tasks[:8])
    lines.append(f"Unread messages: {body.get('unreadMessages', 0) if isinstance(body, dict) else 0}")
    lines.append(f"Runs: {len(runs)} total, {len(running_runs)} running")
    lines.extend(f"- {run_line(run)}" for run in runs[:5])
    return "\n".join(lines)

def format_dispatch(task, message):
    return f"Dispatched task #{task.get('id')} to {task.get('owner') or message.get('toName')}: {task.get('subject')}\nMessage #{message.get('id')} sent to {message.get('toName')}"

if not argv or argv[0] in ("help", "--help", "-h"):
    usage()
    raise SystemExit(0)

cmd, rest = argv[0], argv[1:]
if cmd == "list":
    req("GET", "/api/agent-teams")
elif cmd == "create":
    pos, flags = parse(rest)
    if not pos: raise SystemExit("Usage: metabot teams create <team>")
    req("POST", "/api/agent-teams", {"name": pos[0], "description": flags.get("description"), "actorRole": actor_role(flags)})
elif cmd == "delete":
    pos, flags = parse(rest)
    if not pos: raise SystemExit("Usage: metabot teams delete <team>")
    req("DELETE", f"/api/agent-teams/{enc(pos[0])}", {"actorRole": actor_role(flags)})
elif cmd == "status":
    pos, flags = parse(rest)
    if not pos: raise SystemExit("Usage: metabot teams status <team>")
    status = req_data("GET", f"/api/agent-teams/{enc(pos[0])}")
    emit(format_status(status) if wants_summary(flags) else status)
elif cmd == "bind":
    pos, flags = parse(rest)
    if len(pos) < 2: raise SystemExit("Usage: metabot teams bind <team> <chatId> [--display]")
    current = req_data("GET", f"/api/agent-teams/{enc(pos[0])}")
    team = current.get("team", {}) if isinstance(current, dict) else {}
    chat_ids = list(team.get("chatIds") or [])
    display_chat_ids = list(team.get("displayChatIds") or [])
    target = display_chat_ids if flags.get("display") is True or flags.get("display") == "true" else chat_ids
    if pos[1] not in target:
        target.append(pos[1])
    req("PATCH", f"/api/agent-teams/{enc(pos[0])}", {
        "chatIds": chat_ids,
        "displayChatIds": display_chat_ids,
        "actorRole": actor_role(flags),
    })
elif cmd in ("start", "stop"):
    pos, flags = parse(rest)
    if not pos: raise SystemExit(f"Usage: metabot teams {cmd} <team>")
    req("POST", f"/api/agent-teams/{enc(pos[0])}/{cmd}", {"actorRole": actor_role(flags)})
elif cmd == "activity":
    pos, flags = parse(rest)
    if not pos:
        raise SystemExit("Usage: metabot teams activity <team>")
    params = {}
    for flag_name, query_name in (
        ("agent", "agent"),
        ("run-id", "runId"),
        ("run", "runId"),
        ("task-id", "taskId"),
        ("task", "taskId"),
        ("chat", "chatId"),
        ("chat-id", "chatId"),
        ("source", "source"),
        ("limit", "limit"),
    ):
        if flags.get(flag_name):
            params[query_name] = str(flags.get(flag_name))
    query = ("?" + urllib.parse.urlencode(params)) if params else ""
    body = req_data("GET", f"/api/agent-teams/{enc(pos[0])}/activity{query}")
    emit(format_activity(body) if wants_summary(flags) else body)
elif cmd == "dispatch":
    pos, flags = parse(rest)
    if len(pos) < 3: raise SystemExit("Usage: metabot teams dispatch <team> <agent> <subject>")
    team, agent = pos[0], pos[1]
    subject = " ".join(pos[2:])
    description = flags.get("description")
    task = req_data("POST", f"/api/agent-teams/{enc(team)}/tasks", {
        "subject": subject,
        "description": description,
        "owner": agent,
        "blockedBy": parse_number_list(flags.get("blocked-by")),
    })
    body = flags.get("message")
    if not body:
        parts = [
            f"Start task #{task.get('id')}: {subject}",
            f"\n{description}" if description else "",
            "",
            f"Expected: claim with `metabot teams tasks claim {team} {task.get('id')} {agent}`, then finish with `metabot teams tasks done {team} {task.get('id')} \"<result>\"`.",
        ]
        body = "\n".join(part for part in parts if part)
    message = req_data("POST", f"/api/agent-teams/{enc(team)}/messages", {
        "toName": agent,
        "fromName": flags.get("from") or "lead",
        "summary": (flags.get("summary") if isinstance(flags.get("summary"), str) else None) or f"Task #{task.get('id')}: {subject}",
        "body": body,
    })
    emit(format_dispatch(task, message) if wants_summary(flags) else {"task": task, "message": message})
elif cmd == "next":
    pos, flags = parse(rest)
    if len(pos) < 2: raise SystemExit("Usage: metabot teams next <team> <agent>")
    team, agent = pos[0], pos[1]
    unread = req_data("GET", f"/api/agent-teams/{enc(team)}/messages?to={enc(agent)}&unread=1")
    tasks_body = req_data("GET", f"/api/agent-teams/{enc(team)}/tasks")
    tasks = tasks_body.get("tasks", []) if isinstance(tasks_body, dict) else []
    assigned = [
        task for task in tasks
        if task.get("owner") == agent and task.get("status") in ("pending", "in_progress")
    ]
    result = {
        "team": team,
        "agent": agent,
        "unreadMessages": unread.get("messages", []) if isinstance(unread, dict) else [],
        "assignedTasks": assigned,
    }
    if flags.get("read") and result["unreadMessages"]:
        read = req_data("POST", f"/api/agent-teams/{enc(team)}/messages/read?to={enc(agent)}", {})
        if isinstance(read, dict):
            result["read"] = read.get("read", 0)
    emit(format_next(result) if wants_summary(flags) else result)
elif cmd == "watch":
    pos, flags = parse(rest)
    if not pos: raise SystemExit("Usage: metabot teams watch <team>")
    interval = max(1.0, float(flags.get("interval") or 5))
    count = max(1, int(flags.get("count") or 1))
    for i in range(count):
        status = req_data("GET", f"/api/agent-teams/{enc(pos[0])}")
        emit(format_status(status) if wants_summary(flags) else status)
        if i < count - 1:
            time.sleep(interval)
elif cmd == "templates":
    sub, args = (rest[0] if rest else ""), rest[1:]
    if sub == "list":
        name = args[0] if args else None
        req("GET", "/api/agent-teams/templates" + (f"/{enc(name)}" if name else ""))
    elif sub == "export":
        pos, flags = parse(args)
        name = pos[0] if pos else None
        if not name: raise SystemExit("Usage: metabot teams templates export <name> [--version n]")
        version = flags.get("version")
        req("GET", f"/api/agent-teams/templates/{enc(name)}/export" + (f"?version={enc(version)}" if version else ""))
    elif sub == "diff":
        pos, flags = parse(args)
        name = pos[0] if pos else None
        from_version = flags.get("from")
        if not name or not from_version: raise SystemExit("Usage: metabot teams templates diff <name> --from n [--to n]")
        query = f"?from={enc(from_version)}"
        if flags.get("to"):
            query += f"&to={enc(flags.get('to'))}"
        req("GET", f"/api/agent-teams/templates/{enc(name)}/diff{query}")
    elif sub == "import":
        pos, flags = parse(args)
        raw = " ".join(pos)
        if not raw: raise SystemExit("Usage: metabot teams templates import <json> [--source name]")
        req("POST", "/api/agent-teams/templates", {
            "template": json.loads(raw),
            "source": flags.get("source") or "cli",
            "actorRole": actor_role(flags),
        })
    else:
        raise SystemExit("Usage: metabot teams templates list|export|diff|import ...")
elif cmd == "proposals":
    sub, args = (rest[0] if rest else ""), rest[1:]
    if sub == "list":
        pos, flags = parse(args)
        status = flags.get("status")
        req("GET", "/api/agent-teams/proposals" + (f"?status={enc(status)}" if status else ""))
    elif sub == "create":
        pos, flags = parse(args)
        explicit_kind = pos[0] if pos and pos[0] in ("template", "ruleset") else None
        if explicit_kind:
            pos = pos[1:]
        raw = " ".join(pos)
        if not raw:
            raise SystemExit("Usage: metabot teams proposals create [template|ruleset] <json>")
        parsed = json.loads(raw)
        body = {"kind": explicit_kind, "body": parsed} if explicit_kind else parsed
        if flags.get("summary"):
            body["summary"] = flags.get("summary")
        if flags.get("by"):
            body["requestedBy"] = flags.get("by")
        if flags.get("role"):
            body["requestedByRole"] = flags.get("role")
        req("POST", "/api/agent-teams/proposals", body)
    elif sub in ("approve", "reject"):
        pos, flags = parse(args)
        if not pos:
            raise SystemExit(f"Usage: metabot teams proposals {sub} <id>")
        req("POST", f"/api/agent-teams/proposals/{enc(pos[0])}/{sub}", {
            "actorRole": actor_role(flags),
            "decidedBy": flags.get("by"),
            "reason": flags.get("reason"),
        })
    else:
        raise SystemExit("Usage: metabot teams proposals list|create|approve|reject ...")
elif cmd == "instances":
    sub, args = (rest[0] if rest else ""), rest[1:]
    if sub == "list":
        pos, flags = parse(args)
        template = flags.get("template")
        req("GET", "/api/agent-teams/instances" + (f"?template={enc(template)}" if template else ""))
    elif sub == "resolve":
        pos, flags = parse(args)
        if not pos: raise SystemExit("Usage: metabot teams instances resolve <template> [--chat id|--project id|--global]")
        scope_type = "global" if flags.get("global") else ("project" if flags.get("project") else "chat")
        req("POST", "/api/agent-teams/instances/resolve", {
            "templateName": pos[0],
            "scopeType": scope_type,
            "chatId": flags.get("chat"),
            "projectId": flags.get("project"),
            "pmBot": flags.get("pm-bot"),
            "createIfMissing": True,
            "allowGlobal": bool(flags.get("global")),
            "actorRole": actor_role(flags),
        })
    else:
        raise SystemExit("Usage: metabot teams instances list|resolve ...")
elif cmd == "rules":
    sub, args = (rest[0] if rest else ""), rest[1:]
    if sub == "list":
        name = args[0] if args else None
        req("GET", "/api/agent-teams/rules" + (f"/{enc(name)}" if name else ""))
    elif sub == "set":
        pos, flags = parse(args)
        rules = [{"text": rule} for rule in array_flag(flags, "rule")]
        if not pos or not flags.get("scope") or not rules:
            raise SystemExit("Usage: metabot teams rules set <name> --scope scope --rule text")
        req("POST", "/api/agent-teams/rules", {
            "name": pos[0],
            "scope": flags.get("scope"),
            "rules": rules,
            "source": "cli",
            "actorRole": actor_role(flags),
        })
    elif sub == "context":
        pos, flags = parse(args)
        req("POST", "/api/agent-teams/rules/context", {
            "refs": [parse_rule_ref(ref) for ref in array_flag(flags, "ref")],
            "inlineRules": [{"text": rule} for rule in array_flag(flags, "rule")],
        })
    else:
        raise SystemExit("Usage: metabot teams rules list|set|context ...")
elif cmd == "agents":
    sub, args = (rest[0] if rest else ""), rest[1:]
    if sub == "list":
        if not args: raise SystemExit("Usage: metabot teams agents list <team>")
        req("GET", f"/api/agent-teams/{enc(args[0])}/agents")
    elif sub == "spawn":
        pos, flags = parse(args)
        if len(pos) < 2: raise SystemExit("Usage: metabot teams agents spawn <team> <name>")
        req("POST", f"/api/agent-teams/{enc(pos[0])}/agents", {
            "name": pos[1],
            "role": flags.get("role"),
            "engine": flags.get("engine") or "codex",
            "model": flags.get("model"),
            "reasoningEffort": flags.get("reasoning-effort"),
            "approvalPolicy": flags.get("approval-policy"),
            "sandbox": flags.get("sandbox"),
            "timeoutMs": int(flags["timeout-ms"]) if str(flags.get("timeout-ms") or "").isdigit() else None,
            "idleTimeoutMs": int(flags["idle-timeout-ms"]) if str(flags.get("idle-timeout-ms") or "").isdigit() else None,
            "allowedTools": array_flag(flags, "allowed-tools"),
            "prompt": flags.get("prompt"),
            "actorRole": flags.get("actor-role") or flags.get("as-role"),
        })
    elif sub == "stop":
        pos, flags = parse(args)
        if len(pos) < 2: raise SystemExit("Usage: metabot teams agents stop <team> <name>")
        req("POST", f"/api/agent-teams/{enc(pos[0])}/agents/{enc(pos[1])}/stop", {"actorRole": actor_role(flags)})
    elif sub in ("delete", "remove"):
        pos, flags = parse(args)
        if len(pos) < 2: raise SystemExit(f"Usage: metabot teams agents {sub} <team> <name>")
        req("DELETE", f"/api/agent-teams/{enc(pos[0])}/agents/{enc(pos[1])}", {"actorRole": actor_role(flags)})
    else:
        raise SystemExit("Usage: metabot teams agents list|spawn|stop|delete ...")
elif cmd == "send":
    pos, flags = parse(rest)
    if len(pos) < 2: raise SystemExit("Usage: metabot teams send <team> <to> <message>")
    message = flags.get("message") or " ".join(pos[2:])
    if not message: raise SystemExit("Usage: metabot teams send <team> <to> <message>")
    req("POST", f"/api/agent-teams/{enc(pos[0])}/messages", {
        "toName": pos[1], "body": message, "fromName": flags.get("from"), "summary": flags.get("summary")
    })
elif cmd == "inbox":
    pos, flags = parse(rest)
    if len(pos) < 2: raise SystemExit("Usage: metabot teams inbox <team> <name>")
    q = f"?to={enc(pos[1])}" + ("&unread=1" if flags.get("unread") else "")
    inbox = req_data("GET", f"/api/agent-teams/{enc(pos[0])}/messages{q}")
    if flags.get("read"):
        read = req_data("POST", f"/api/agent-teams/{enc(pos[0])}/messages/read?to={enc(pos[1])}", {})
        if isinstance(inbox, dict) and isinstance(read, dict):
            inbox["read"] = read.get("read", 0)
    emit(format_inbox(inbox) if wants_summary(flags) else inbox)
elif cmd == "tasks":
    sub, args = (rest[0] if rest else ""), rest[1:]
    if sub == "list":
        pos, flags = parse(args)
        if not pos: raise SystemExit("Usage: metabot teams tasks list <team>")
        tasks = req_data("GET", f"/api/agent-teams/{enc(pos[0])}/tasks")
        emit(format_tasks(tasks) if wants_summary(flags) else tasks)
    elif sub == "create":
        pos, flags = parse(args)
        if len(pos) < 2: raise SystemExit("Usage: metabot teams tasks create <team> <subject>")
        req("POST", f"/api/agent-teams/{enc(pos[0])}/tasks", {
            "subject": " ".join(pos[1:]), "description": flags.get("description"), "owner": flags.get("owner"),
            "blockedBy": parse_number_list(flags.get("blocked-by"))
        })
    elif sub == "get":
        if len(args) < 2: raise SystemExit("Usage: metabot teams tasks get <team> <id>")
        req("GET", f"/api/agent-teams/{enc(args[0])}/tasks/{enc(args[1])}")
    elif sub == "update":
        pos, flags = parse(args)
        if len(pos) < 2: raise SystemExit("Usage: metabot teams tasks update <team> <id>")
        req("PATCH", f"/api/agent-teams/{enc(pos[0])}/tasks/{enc(pos[1])}", {
            "subject": flags.get("subject"),
            "description": flags.get("description"),
            "status": flags.get("status"),
            "owner": None if flags.get("owner") == "none" else flags.get("owner"),
            "__keepNull": ["owner"] if flags.get("owner") == "none" else [],
            "blockedBy": parse_number_list(flags.get("blocked-by")),
            "result": flags.get("result"),
        })
    elif sub == "claim":
        pos, flags = parse(args)
        owner = flags.get("owner") or (pos[2] if len(pos) >= 3 else None) or default_agent_name()
        if len(pos) < 2 or not owner: raise SystemExit("Usage: metabot teams tasks claim <team> <id> [owner|--owner name]")
        req("PATCH", f"/api/agent-teams/{enc(pos[0])}/tasks/{enc(pos[1])}", {
            "status": "in_progress", "owner": owner
        })
    elif sub in ("done", "complete"):
        pos, flags = parse(args)
        result = flags.get("result") or (" ".join(pos[2:]) if len(pos) >= 3 else "")
        if len(pos) < 2 or not result: raise SystemExit(f"Usage: metabot teams tasks {sub} <team> <id> <result>")
        req("PATCH", f"/api/agent-teams/{enc(pos[0])}/tasks/{enc(pos[1])}", {
            "status": "completed", "result": result
        })
    elif sub == "block":
        pos, flags = parse(args)
        reason = flags.get("result") or (" ".join(pos[2:]) if len(pos) >= 3 else "")
        if len(pos) < 2 or not reason: raise SystemExit("Usage: metabot teams tasks block <team> <id> <reason>")
        req("PATCH", f"/api/agent-teams/{enc(pos[0])}/tasks/{enc(pos[1])}", {
            "status": "pending",
            "blockedBy": parse_number_list(flags.get("blocked-by")),
            "result": f"Blocked: {reason}",
        })
    elif sub == "reopen":
        if len(args) < 2: raise SystemExit("Usage: metabot teams tasks reopen <team> <id>")
        req("PATCH", f"/api/agent-teams/{enc(args[0])}/tasks/{enc(args[1])}", {
            "status": "pending"
        })
    else:
        raise SystemExit("Usage: metabot teams tasks list|create|get|update|claim|done|block|reopen ...")
elif cmd == "runs":
    sub, args = (rest[0] if rest else ""), rest[1:]
    if sub == "list":
        pos, flags = parse(args)
        if not pos: raise SystemExit("Usage: metabot teams runs list <team>")
        runs = req_data("GET", f"/api/agent-teams/{enc(pos[0])}/runs")
        emit(format_runs(runs) if wants_summary(flags) else runs)
    elif sub == "create":
        pos, flags = parse(args)
        if not pos: raise SystemExit("Usage: metabot teams runs create <team>")
        task_id = flags.get("task-id")
        req("POST", f"/api/agent-teams/{enc(pos[0])}/runs", {
            "agentName": flags.get("agent"), "taskId": int(task_id) if task_id else None,
            "status": flags.get("status"), "output": flags.get("output"), "error": flags.get("error")
        })
    elif sub == "update":
        pos, flags = parse(args)
        if len(pos) < 2: raise SystemExit("Usage: metabot teams runs update <team> <runId>")
        req("PATCH", f"/api/agent-teams/{enc(pos[0])}/runs/{enc(pos[1])}", {
            "status": flags.get("status"), "output": flags.get("output"), "error": flags.get("error")
        })
    elif sub in ("output", "stop"):
        if len(args) < 2: raise SystemExit(f"Usage: metabot teams runs {sub} <team> <runId>")
        if sub == "output":
            req("GET", f"/api/agent-teams/{enc(args[0])}/runs/{enc(args[1])}/output")
        else:
            pos, flags = parse(args)
            req("POST", f"/api/agent-teams/{enc(pos[0])}/runs/{enc(pos[1])}/stop", {"actorRole": actor_role(flags)})
    else:
        raise SystemExit("Usage: metabot teams runs list|create|update|output|stop ...")
else:
    raise SystemExit(f"Unknown metabot teams command: {cmd}")
PY
      ;;
    health|h)
      curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/health" | _json
      ;;
  esac
}

print_help() {
  echo -e "${BOLD}metabot${NC} - MetaBot CLI"
  echo ""
  echo "  Process control:"
  echo "    metabot update        Refresh from internal package, rebuild, and restart"
  echo "    metabot update --git  Developer-only: git pull, rebuild, and restart"
  echo "    metabot start      Start MetaBot with PM2"
  echo "    metabot stop       Stop MetaBot"
  echo "    metabot restart    Restart MetaBot"
  echo "    metabot deploy-runtime --runtime DIR  Atomically switch runtime from an external controller"
  echo "    metabot logs       View live logs (pass -n 100 etc.)"
  echo "    metabot status     Show PM2 process status"
  echo "    metabot doctor     Agent-readable runtime diagnostics (--json)"
  echo ""
  echo "  Bridge daemon API (localhost:9100):"
  echo "    metabot bots                       List all bots (local + peer)"
  echo "    metabot bot <name>                 Get bot details"
  echo "    metabot talk [--async|--sync] [--no-cards] [--wait-ms N] <bot> <chatId> <msg>  Talk to a bot (defaults to bounded wait, then task status)"
  echo "    metabot talk-status <taskId>       Check an async talk task with local auth"
  echo "    metabot schedule …                 Task scheduling (list/add/cron/pause/resume/cancel)"
  echo "    metabot teams …                    MetaBot Agent Teams (agents/tasks/messages/runs)"
  echo "    metabot peers                      List peers and their status"
  echo "    metabot stats                      Cost & usage stats"
  echo "    metabot metrics                    Prometheus metrics"
  echo "    metabot voice …                    RTC voice call + TTS (call/transcript/list/config/tts)"
  echo "    metabot health                     Health check"
  echo ""
  echo "  Feature subcommands (delegated to metabot-core):"
  echo "    metabot t5t … | agents … | memory … | skills …"
}

case "${1:-}" in
  update|up)    shift; cmd_update "$@" ;;
  start)        cmd_start ;;
  stop)         cmd_stop ;;
  restart|rs)   shift; cmd_restart "$@" ;;
  deploy-runtime) shift; cmd_deploy_runtime "$@" ;;
  logs|log)     shift; cmd_logs "$@" ;;
  status|st)    cmd_status ;;
  doctor)       shift; cmd_doctor "$@" ;;
  bots|b|bot|talk|t|talk-status|ts|schedule|sched|sc|peers|p|stats|metrics|m|voice|v|teams|team|health|h)
                cmd_bridge_api "$@" ;;
  ""|help|--help|-h) print_help ;;
  *)            cmd_delegate "$@" ;;
esac
