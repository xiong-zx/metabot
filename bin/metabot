#!/usr/bin/env bash
# metabot - MetaBot CLI (single binary)
# Three command categories:
#   1. Bridge process control: update | start | stop | restart | logs | status
#   2. Bridge daemon API (localhost:9100): bots | bot | talk | schedule |
#      peers | stats | metrics | voice | bot-skills | health
#   3. metabot-core delegation: t5t | agents | memory | skills

set -euo pipefail

# Resolve METABOT_HOME: env var > script's parent dir (follows symlinks) > $HOME/metabot
if [[ -z "${METABOT_HOME:-}" ]]; then
  _src="${BASH_SOURCE[0]}"
  if command -v readlink &>/dev/null; then
    _src="$(readlink -f "$_src" 2>/dev/null || echo "$_src")"
  fi
  _sd="$(cd "$(dirname "$_src")/.." 2>/dev/null && pwd)" || _sd=""
  if [[ -n "$_sd" && -d "$_sd/.git" && -f "$_sd/package.json" ]]; then
    METABOT_HOME="$_sd"
  else
    METABOT_HOME="$HOME/metabot"
  fi
fi

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

info()    { echo -e "${BLUE}[INFO]${NC} $*"; }
success() { echo -e "${GREEN}[OK]${NC} $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC} $*"; }
error()   { echo -e "${RED}[ERROR]${NC} $*"; }

# --- Bridge daemon API config (Category 2): env vars > .env file > defaults ---
# Read API_PORT / API_SECRET / METABOT_URL from $METABOT_HOME/.env without
# clobbering values already exported in the environment.
_load_bridge_api_config() {
  local envf="$METABOT_HOME/.env"
  if [[ -f "$envf" ]]; then
    _api_port=$(sed -n 's/^API_PORT=//p' "$envf" 2>/dev/null || true)
    _api_secret=$(sed -n 's/^API_SECRET=//p' "$envf" 2>/dev/null || true)
    _api_url=$(sed -n 's/^METABOT_URL=//p' "$envf" 2>/dev/null || true)
  fi
  METABOT_URL="${METABOT_URL:-${_api_url:-http://localhost:${_api_port:-9100}}}"
  _api_secret="${_api_secret:-${API_SECRET:-changeme}}"
  METABOT_AUTH="Authorization: Bearer $_api_secret"
}

_json() { python3 -m json.tool 2>/dev/null || cat; }

cmd_update() {
  if [[ ! -d "$METABOT_HOME/.git" ]]; then
    error "MetaBot not found at $METABOT_HOME"
    echo "  Run the installer first: curl -fsSL https://raw.githubusercontent.com/xvirobotics/metabot/main/install.sh | bash"
    exit 1
  fi

  # Always re-exec from the repo copy before doing anything.
  # This prevents the running script (e.g. ~/.local/bin/metabot) from being
  # overwritten mid-execution when we copy CLI tools later.
  if [[ -z "${METABOT_REEXEC:-}" ]] && [[ -f "$METABOT_HOME/bin/metabot" ]]; then
    export METABOT_REEXEC=1
    exec "$METABOT_HOME/bin/metabot" update
  fi

  info "Pulling latest code..."
  cd "$METABOT_HOME"
  local old_head
  old_head="$(git rev-parse HEAD)"
  git pull --ff-only || { error "git pull failed"; exit 1; }

  # Re-exec if git pull updated this script (the repo copy we're running from)
  if ! git diff --quiet "$old_head" HEAD -- bin/metabot 2>/dev/null; then
    info "metabot CLI updated, re-launching with new version..."
    exec "$METABOT_HOME/bin/metabot" update
  fi

  info "Installing dependencies..."
  npm install --production=false

  info "Building..."
  npm run build

  # Update CLI tools in ~/.local/bin.
  # `mb` is the bridge inter-bot API shortcut; `metabot` is the dual
  # dispatcher (bridge process control + delegate to metabot-core feature CLI).
  # `mm`/`mh`/`mbcore` are Phase-4 legacy and stay removed.
  LOCAL_BIN="$HOME/.local/bin"
  if [[ -d "$LOCAL_BIN" ]]; then
    info "Updating CLI tools..."
    for cli in mb metabot; do
      local src="$METABOT_HOME/bin/$cli"
      local dst="$LOCAL_BIN/$cli"
      if [[ -f "$src" ]]; then
        # Skip when $dst already points at $src — copying a file onto its own
        # symlink target errors out with `cp: 'a' and 'b' are the same file`.
        if [[ "$src" -ef "$dst" ]]; then
          continue
        fi
        cp "$src" "$dst"
        chmod +x "$dst"
      fi
    done
    # Clean up legacy CLIs (Phase 4 consolidation + temp shims).
    for legacy_cli in mm mh mbcore fd; do
      if [[ -f "$LOCAL_BIN/$legacy_cli" || -L "$LOCAL_BIN/$legacy_cli" ]]; then
        rm -f "$LOCAL_BIN/$legacy_cli"
      fi
    done
    success "CLI tools updated"
  fi

  # Update skills in ~/.claude/skills and ~/.codex/skills
  SKILLS_DIR="$HOME/.claude/skills"
  CODEX_SKILLS_DIR="$HOME/.codex/skills"
  AGENTS_SKILLS_DIR="$HOME/.agents/skills"
  mkdir -p "$SKILLS_DIR" "$CODEX_SKILLS_DIR"
  info "Updating skills..."
  local src=""
  local -a lark_skill_names=(
    lark-base
    lark-calendar
    lark-contact
    lark-doc
    lark-drive
    lark-event
    lark-im
    lark-mail
    lark-minutes
    lark-openapi-explorer
    lark-shared
    lark-sheets
    lark-skill-maker
    lark-task
    lark-vc
    lark-whiteboard
    lark-wiki
    lark-workflow-meeting-summary
    lark-workflow-standup-report
  )
  # Phase 4 consolidation: `metamemory` and `skill-hub` skill bundles are
  # subsumed by the unified `metabot` skill (which delegates memory/skills/
  # agents/t5t to the metabot-core feature CLI). metaskill / metaschedule
  # remain opt-in; sources still ship in src/skills/* for manual copy.
  for skill in metabot voice; do
    case "$skill" in
      metabot) src="$METABOT_HOME/packages/skills/metabot" ;;
      voice)   src="$METABOT_HOME/src/skills/voice" ;;
      *)       src="" ;;
    esac
    if [[ -n "$src" && -d "$src" ]]; then
      for dst_root in "$SKILLS_DIR" "$CODEX_SKILLS_DIR"; do
        mkdir -p "$dst_root/$skill"
        cp -r "$src/." "$dst_root/$skill/"
      done
    fi
  done
  # Strip legacy skill bundles (Phase 4 consolidation).
  for legacy in metamemory skill-hub; do
    for dst_root in "$SKILLS_DIR" "$CODEX_SKILLS_DIR"; do
      if [[ -d "$dst_root/$legacy" ]]; then
        rm -rf "$dst_root/$legacy"
        info "Removed legacy $legacy skill from $dst_root (use \`metabot ${legacy/skill-hub/skills}\` instead)"
      fi
    done
  done
  # Clean up legacy feishu-doc skill
  if [[ -d "$SKILLS_DIR/feishu-doc" ]]; then
    rm -rf "$SKILLS_DIR/feishu-doc"
    info "Removed legacy feishu-doc skill"
  fi
  if [[ -d "$CODEX_SKILLS_DIR/feishu-doc" ]]; then
    rm -rf "$CODEX_SKILLS_DIR/feishu-doc"
  fi
  # Clean up legacy metaskill — now opt-in. Override with KEEP_METASKILL=1.
  if [[ -d "$SKILLS_DIR/metaskill" ]] && [[ "${KEEP_METASKILL:-}" != "1" ]]; then
    rm -rf "$SKILLS_DIR/metaskill"
    info "Removed legacy metaskill (opt-in — set KEEP_METASKILL=1 to keep)"
  fi
  if [[ -d "$CODEX_SKILLS_DIR/metaskill" ]] && [[ "${KEEP_METASKILL:-}" != "1" ]]; then
    rm -rf "$CODEX_SKILLS_DIR/metaskill"
  fi

  # Update lark-cli and its AI Agent skills only if previously installed.
  # New installs still opt in via install.sh; updates keep existing setups fresh.
  local has_lark_skills=false
  local skill_root
  for skill_root in "$AGENTS_SKILLS_DIR" "$SKILLS_DIR" "$CODEX_SKILLS_DIR"; do
    if [[ -d "$skill_root/lark-doc" ]]; then
      has_lark_skills=true
      break
    fi
  done
  if command -v lark-cli &>/dev/null; then
    info "Updating lark-cli..."
    if npm install -g @larksuite/cli@latest 2>/dev/null || npm install -g --prefix "$HOME/.local" @larksuite/cli@latest 2>/dev/null; then
      success "lark-cli updated ($(lark-cli --version 2>/dev/null || echo 'version unknown'))"
    else
      warn "lark-cli update failed; MetaBot update will continue"
    fi
    has_lark_skills=true
  fi
  if [[ "$has_lark_skills" == "true" ]]; then
    info "Updating lark-cli AI Agent skills..."
    if npx skills add larksuite/cli --all -y -g 2>/dev/null; then
      success "lark-cli AI Agent skills updated"
    else
      warn "lark-cli skills update failed; keeping existing installed copies"
    fi
    # Mirror lark-cli skills into Claude/Codex skill roots. Recent lark-cli
    # installs use ~/.agents/skills, while older installs may use ~/.claude.
    local lark_skill
    for lark_skill in "${lark_skill_names[@]}"; do
      local lark_src=""
      for skill_root in "$AGENTS_SKILLS_DIR" "$SKILLS_DIR" "$CODEX_SKILLS_DIR"; do
        if [[ -d "$skill_root/$lark_skill" ]]; then
          lark_src="$skill_root/$lark_skill"
          break
        fi
      done
      if [[ -n "$lark_src" ]]; then
        for dst_root in "$SKILLS_DIR" "$CODEX_SKILLS_DIR"; do
          mkdir -p "$dst_root/$lark_skill"
          # Skip when src and dst already resolve to the same inode
          # (lark-cli installs ~/.agents/skills/* and symlinks them into
          # ~/.claude/skills + ~/.codex/skills — cp would error on same-file).
          [[ "$lark_src" -ef "$dst_root/$lark_skill" ]] && continue
          if [[ "$lark_src" != "$dst_root/$lark_skill" ]]; then
            cp -r "$lark_src/." "$dst_root/$lark_skill/"
          fi
        done
      fi
    done
  fi
  success "Skills updated"

  # Update workspace skills if bots.json exists
  if [[ -f "$METABOT_HOME/bots.json" ]] && command -v node &>/dev/null; then
    local work_dir
    work_dir=$(node -e "
      const c=JSON.parse(require('fs').readFileSync('$METABOT_HOME/bots.json','utf-8'));
      const b=[...(c.feishuBots||[]),...(c.telegramBots||[]),...(c.wechatBots||[])];
      if(b[0])console.log(b[0].defaultWorkingDirectory);
    " 2>/dev/null || true)
    if [[ -n "$work_dir" ]]; then
      local ws_skills_dir="$work_dir/.claude/skills"
      local ws_codex_skills_dir="$work_dir/.codex/skills"
      mkdir -p "$ws_skills_dir" "$ws_codex_skills_dir"

      # Copy common skills (Phase 4: metamemory/skill-hub removed).
      for skill in metabot voice; do
        if [[ -d "$SKILLS_DIR/$skill" ]]; then
          for dst_root in "$ws_skills_dir" "$ws_codex_skills_dir"; do
            mkdir -p "$dst_root/$skill"
            cp -r "$SKILLS_DIR/$skill/." "$dst_root/$skill/"
          done
        fi
      done
      # Strip legacy skill bundles from a previously-deployed workspace.
      for legacy in metamemory skill-hub; do
        for dst_root in "$ws_skills_dir" "$ws_codex_skills_dir"; do
          if [[ -d "$dst_root/$legacy" ]]; then
            rm -rf "$dst_root/$legacy"
          fi
        done
      done
      # Mirror opt-in skills (metaskill / metaschedule) only when present.
      for skill in metaskill metaschedule; do
        if [[ -d "$SKILLS_DIR/$skill" ]]; then
          for dst_root in "$ws_skills_dir" "$ws_codex_skills_dir"; do
            mkdir -p "$dst_root/$skill"
            cp -r "$SKILLS_DIR/$skill/." "$dst_root/$skill/"
          done
        fi
      done
      # Copy lark-cli skills if previously installed
      if [[ "$has_lark_skills" == "true" ]]; then
        local lark_skill
        for lark_skill in "${lark_skill_names[@]}"; do
          local lark_src=""
          for skill_root in "$AGENTS_SKILLS_DIR" "$SKILLS_DIR" "$CODEX_SKILLS_DIR"; do
            if [[ -d "$skill_root/$lark_skill" ]]; then
              lark_src="$skill_root/$lark_skill"
              break
            fi
          done
          if [[ -n "$lark_src" ]]; then
            for dst_root in "$ws_skills_dir" "$ws_codex_skills_dir"; do
              mkdir -p "$dst_root/$lark_skill"
              [[ "$lark_src" -ef "$dst_root/$lark_skill" ]] && continue
              cp -r "$lark_src/." "$dst_root/$lark_skill/"
            done
          fi
        done
      fi
      # Clean up legacy feishu-doc in workspace
      if [[ -d "$ws_skills_dir/feishu-doc" ]]; then
        rm -rf "$ws_skills_dir/feishu-doc"
      fi
      if [[ -d "$ws_codex_skills_dir/feishu-doc" ]]; then
        rm -rf "$ws_codex_skills_dir/feishu-doc"
      fi
      # Update CLAUDE.md
      if [[ -f "$METABOT_HOME/src/workspace/CLAUDE.md" ]]; then
        cp "$METABOT_HOME/src/workspace/CLAUDE.md" "$work_dir/CLAUDE.md"
        if [[ ! -e "$work_dir/AGENTS.md" ]]; then
          cp "$METABOT_HOME/src/workspace/CLAUDE.md" "$work_dir/AGENTS.md"
        fi
      fi
      success "Workspace skills updated"
    fi
  fi

  info "Restarting MetaBot..."
  pm2 restart metabot 2>/dev/null || pm2 start ecosystem.config.cjs
  pm2 save --force 2>/dev/null || true

  success "MetaBot updated and restarted!"

  _update_core_workspace || true
}

# Optimization: if a sibling metabot-core checkout exists, pull + build it so
# the delegated feature CLI (`metabot t5t/agents/memory/skills`) stays in sync
# with the central server. Best-effort — failures don't break the bridge update.
_update_core_workspace() {
  local core_dir="$METABOT_HOME/../metabot-workspace/metabot-core"
  if [[ ! -d "$core_dir/.git" || ! -f "$core_dir/package.json" ]]; then
    return 0
  fi
  echo ""
  info "Updating sibling metabot-core workspace at $core_dir ..."
  (
    cd "$core_dir"
    if ! git pull --ff-only; then
      warn "metabot-core: git pull --ff-only failed (uncommitted changes?). Skipping build."
      exit 1
    fi
    info "metabot-core: installing dependencies..."
    npm install --include=dev --silent || {
      warn "metabot-core: npm install failed."
      exit 1
    }
    info "metabot-core: building..."
    npm run build || {
      warn "metabot-core: build failed."
      exit 1
    }
  ) && success "metabot-core workspace updated" || warn "metabot-core workspace update incomplete (feature CLI may be stale)"
}

cmd_start()   { pm2 start "$METABOT_HOME/ecosystem.config.cjs"; pm2 save --force 2>/dev/null || true; }
cmd_stop()    { pm2 stop metabot; }
cmd_restart() { pm2 restart metabot; }
cmd_logs()    { pm2 logs metabot "${@}"; }
cmd_status()  { pm2 describe metabot; }

# Resolve the metabot-core feature CLI (t5t/agents/memory/skills).
# Order: explicit override > in-tree monorepo > sibling workspace > npm-global on PATH.
_resolve_core_cli() {
  if [[ -n "${METABOT_CORE_CLI:-}" && -x "$METABOT_CORE_CLI" ]]; then
    echo "$METABOT_CORE_CLI"; return 0
  fi
  # In-tree (monorepo): packages/cli is shipped alongside this script.
  local intree="$METABOT_HOME/packages/cli/bin/metabot"
  if [[ -f "$intree" ]]; then
    echo "$intree"; return 0
  fi
  # Sibling workspace (legacy two-repo layout — kept during migration).
  local ws="$METABOT_HOME/../metabot-workspace/metabot-core/packages/cli/bin/metabot"
  if [[ -f "$ws" ]]; then
    echo "$ws"; return 0
  fi
  # npm-linked global: a `metabot-core` bin on PATH (NOT this script).
  local g
  g="$(command -v metabot-core 2>/dev/null || true)"
  if [[ -n "$g" ]]; then echo "$g"; return 0; fi
  return 1
}

cmd_delegate() {
  local core_cli
  if ! core_cli="$(_resolve_core_cli)"; then
    error "'metabot $1' needs the metabot-core CLI, which isn't installed here."
    echo "  Fix one of:" >&2
    echo "    - Build the in-tree CLI: cd \"$METABOT_HOME\" && npm ci && npx tsc -b" >&2
    echo "    - Or point at it:        export METABOT_CORE_CLI=/path/to/packages/cli/bin/metabot" >&2
    exit 1
  fi
  # Feed METABOT_CORE_URL / METABOT_CORE_TOKEN from the bridge .env WITHOUT
  # clobbering values already set in the environment.
  local envf="$METABOT_HOME/.env"
  if [[ -f "$envf" ]]; then
    local k
    for k in METABOT_CORE_URL METABOT_CORE_TOKEN; do
      if [[ -z "${!k:-}" ]]; then
        local line
        line="$(grep -E "^${k}=" "$envf" | tail -n1 || true)"
        if [[ -n "$line" ]]; then
          export "${k}=$(printf '%s' "${line#${k}=}" | sed -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'\$//")"
        fi
      fi
    done
  fi
  exec node "$core_cli" "$@"
}

# --- Category 2: bridge daemon API (curls the local bridge at localhost:9100) ---
cmd_bridge_api() {
  _load_bridge_api_config
  local cmd="$1"; shift 2>/dev/null || true
  case "$cmd" in
    bots|b)
      curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/bots" | _json
      ;;
    bot)
      curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/bots/$1" | _json
      ;;
    talk|t)
      local bot="$1" chat="$2"; shift 2 2>/dev/null || true
      local prompt="$*"
      if [[ -z "${bot:-}" || -z "${chat:-}" || -z "${prompt:-}" ]]; then
        echo "Usage: metabot talk [peer/]<botName> <chatId> <prompt>"
        echo "  Examples:"
        echo "    metabot talk mybot chat123 'fix the bug'"
        echo "    metabot talk alice/backend-bot chat123 'deploy to staging'"
        exit 1
      fi
      python3 -c "
import json, sys
print(json.dumps({'botName': sys.argv[1], 'chatId': sys.argv[2], 'prompt': sys.argv[3], 'sendCards': True}))
" "$bot" "$chat" "$prompt" | \
      curl -s -X POST "$METABOT_URL/api/talk" \
        -H "$METABOT_AUTH" -H "Content-Type: application/json" \
        -d @-
      ;;
    schedule|sched|sc)
      local subcmd="${1:-list}"; shift 2>/dev/null || true
      case "$subcmd" in
        list|ls)
          curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/schedule" | _json
          ;;
        add|a)
          local bot="$1" chat="$2" delay="$3"; shift 3 2>/dev/null || true
          local prompt="$*"
          if [[ -z "${bot:-}" || -z "${chat:-}" || -z "${delay:-}" || -z "${prompt:-}" ]]; then
            echo "Usage: metabot schedule add <botName> <chatId> <delaySeconds> <prompt>"
            exit 1
          fi
          python3 -c "
import json, sys
print(json.dumps({'botName': sys.argv[1], 'chatId': sys.argv[2], 'delaySeconds': int(sys.argv[3]), 'prompt': sys.argv[4]}))
" "$bot" "$chat" "$delay" "$prompt" | \
          curl -s -X POST "$METABOT_URL/api/schedule" \
            -H "$METABOT_AUTH" -H "Content-Type: application/json" \
            -d @- | _json
          ;;
        cron|c)
          local bot="$1" chat="$2" cron_expr="$3"; shift 3 2>/dev/null || true
          local prompt="$*"
          if [[ -z "${bot:-}" || -z "${chat:-}" || -z "${cron_expr:-}" || -z "${prompt:-}" ]]; then
            echo "Usage: metabot schedule cron <botName> <chatId> '<cronExpr>' <prompt>"
            echo "  Example: metabot schedule cron mybot oc_xxx '0 8 * * 1-5' Generate daily report"
            exit 1
          fi
          python3 -c "
import json, sys
print(json.dumps({'botName': sys.argv[1], 'chatId': sys.argv[2], 'cronExpr': sys.argv[3], 'prompt': sys.argv[4]}))
" "$bot" "$chat" "$cron_expr" "$prompt" | \
          curl -s -X POST "$METABOT_URL/api/schedule" \
            -H "$METABOT_AUTH" -H "Content-Type: application/json" \
            -d @- | _json
          ;;
        pause|p)
          if [[ -z "${1:-}" ]]; then echo "Usage: metabot schedule pause <id>"; exit 1; fi
          curl -s -X POST "$METABOT_URL/api/schedule/$1/pause" -H "$METABOT_AUTH" | _json
          ;;
        resume|r)
          if [[ -z "${1:-}" ]]; then echo "Usage: metabot schedule resume <id>"; exit 1; fi
          curl -s -X POST "$METABOT_URL/api/schedule/$1/resume" -H "$METABOT_AUTH" | _json
          ;;
        cancel|rm)
          if [[ -z "${1:-}" ]]; then echo "Usage: metabot schedule cancel <id>"; exit 1; fi
          curl -s -X DELETE "$METABOT_URL/api/schedule/$1" -H "$METABOT_AUTH" | _json
          ;;
        *)
          echo "metabot schedule - Task scheduling"
          echo "  metabot schedule list                                    - List all scheduled tasks"
          echo "  metabot schedule add <bot> <chatId> <delaySec> <prompt>  - Schedule a one-time task"
          echo "  metabot schedule cron <bot> <chatId> '<cron>' <prompt>   - Schedule a recurring task"
          echo "  metabot schedule pause <id>                              - Pause a recurring task"
          echo "  metabot schedule resume <id>                             - Resume a paused task"
          echo "  metabot schedule cancel <id>                             - Cancel a task"
          ;;
      esac
      ;;
    peers|p)
      curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/peers" | _json
      ;;
    stats)
      curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/stats" | _json
      ;;
    metrics|m)
      curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/metrics"
      ;;
    voice|v)
      local subcmd="${1:-help}"; shift 2>/dev/null || true
      case "$subcmd" in
        call|c)
          local bot="${1:-}" chat="${2:-}"; shift 2 2>/dev/null || true
          local _welcome=""
          local _prompt=""
          while [[ $# -gt 0 ]]; do
            case "$1" in
              -w|--welcome) _welcome="$2"; shift 2 ;;
              *)            _prompt="${_prompt:+$_prompt }$1"; shift ;;
            esac
          done
          if [[ -z "${bot:-}" || -z "${chat:-}" ]]; then
            echo "Usage: metabot voice call <botName> <chatId> [prompt] [-w welcomeMessage]"
            echo "  Initiates an RTC voice call. Notifies the web/iOS user,"
            echo "  waits for the call to end, and returns the transcript."
            echo ""
            echo "  Options:"
            echo "    -w, --welcome <text>  AI's opening line (what it says first)"
            echo ""
            echo "  Examples:"
            echo "    metabot voice call whis chat123 'Tell user they are awesome' -w 'Flood, 你是最棒的！'"
            echo "    metabot voice call whis chat123 -w 'Hi! I wanted to discuss the project progress.'"
            exit 1
          fi
          echo "Starting voice call... (waiting for user to join and call to end)"
          python3 -c "
import json, sys
p = {'botName': sys.argv[1], 'chatId': sys.argv[2]}
if sys.argv[3]: p['prompt'] = sys.argv[3]
if sys.argv[4]: p['welcomeMessage'] = sys.argv[4]
print(json.dumps(p))
" "$bot" "$chat" "${_prompt:-}" "${_welcome:-}" | \
          curl -s -X POST "$METABOT_URL/api/rtc/voice?wait=true" \
            -H "$METABOT_AUTH" -H "Content-Type: application/json" \
            --max-time 660 \
            -d @- | _json
          ;;
        transcript|t)
          if [[ -z "${1:-}" ]]; then echo "Usage: metabot voice transcript <sessionId>"; exit 1; fi
          curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/rtc/transcript?sessionId=$1" | _json
          ;;
        list|ls)
          curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/rtc/sessions" | _json
          ;;
        config)
          curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/rtc/config" | _json
          ;;
        tts)
          local _provider=""
          local _voice=""
          local _output=""
          local _play=false
          local _text=""
          while [[ $# -gt 0 ]]; do
            case "$1" in
              --provider|-p) _provider="$2"; shift 2 ;;
              --voice)       _voice="$2"; shift 2 ;;
              -o|--output)   _output="$2"; shift 2 ;;
              --play)        _play=true; shift ;;
              --)            shift; _text="$*"; break ;;
              -*)            echo "Unknown flag: $1"; exit 1 ;;
              *)             _text="$*"; break ;;
            esac
          done
          if [[ -z "$_text" ]]; then
            if [[ -t 0 ]]; then
              echo "Usage: metabot voice tts \"text\" [--play] [-o file.mp3] [--provider doubao|openai|elevenlabs] [--voice <name>]"
              echo "  Or pipe text: echo 'hello' | metabot voice tts"
              exit 1
            fi
            _text="$(cat)"
          fi
          local _json_body
          _json_body=$(python3 -c "
import json, sys
body = {'text': sys.argv[1]}
if sys.argv[2]: body['provider'] = sys.argv[2]
if sys.argv[3]: body['voice'] = sys.argv[3]
print(json.dumps(body))
" "$_text" "$_provider" "$_voice")
          if [[ -z "$_output" ]]; then
            _output="/tmp/metabot-voice-$(date +%s).mp3"
          fi
          local _http_code
          _http_code=$(curl -s -w '%{http_code}' -o "$_output" \
            -X POST "$METABOT_URL/api/tts" \
            -H "$METABOT_AUTH" -H "Content-Type: application/json" \
            -d "$_json_body")
          if [[ "$_http_code" != "200" ]]; then
            echo "Error: TTS request failed (HTTP $_http_code)"
            cat "$_output" 2>/dev/null
            rm -f "$_output"
            exit 1
          fi
          echo "$_output"
          if [[ "$_play" == "true" ]]; then
            if command -v afplay &>/dev/null; then afplay "$_output"
            elif command -v mpv &>/dev/null; then mpv --no-video "$_output" 2>/dev/null
            elif command -v ffplay &>/dev/null; then ffplay -nodisp -autoexit "$_output" 2>/dev/null
            elif command -v play &>/dev/null; then play "$_output" 2>/dev/null
            else echo "(no audio player found — install mpv, ffplay, or sox to use --play)"
            fi
          fi
          ;;
        *)
          echo "metabot voice - Voice tools"
          echo ""
          echo "  RTC Voice Call:"
          echo "    metabot voice call <bot> <chatId> [prompt] [-w opening]  - Start voice call"
          echo "    metabot voice transcript <sessionId>     - Get call transcript"
          echo "    metabot voice list                       - List active voice sessions"
          echo "    metabot voice config                     - Check RTC configuration"
          echo ""
          echo "  Text-to-Speech:"
          echo "    metabot voice tts \"text\" [--play] [-o f]  - Generate MP3 from text"
          echo "    metabot voice tts \"text\" --provider doubao - Use specific TTS provider"
          echo "    echo 'hello' | metabot voice tts           - Read from stdin"
          ;;
      esac
      ;;
    bot-skills)
      local subcmd="${1:-list}"; shift 2>/dev/null || true
      case "$subcmd" in
        list|ls)
          curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/skills" | _json
          ;;
        search|s)
          local query="$*"
          if [[ -z "${query:-}" ]]; then echo "Usage: metabot bot-skills search <query>"; exit 1; fi
          curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/skills/search?q=$(python3 -c 'import urllib.parse,sys;print(urllib.parse.quote(sys.argv[1]))' "$query")" | _json
          ;;
        get|g)
          if [[ -z "${1:-}" ]]; then echo "Usage: metabot bot-skills get <name>"; exit 1; fi
          curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/skills/$1" | _json
          ;;
        publish|pub)
          local bot="${1:-}" skill="${2:-}"
          if [[ -z "$bot" || -z "$skill" ]]; then
            echo "Usage: metabot bot-skills publish <botName> <skillName>"
            exit 1
          fi
          curl -s -X POST "$METABOT_URL/api/skills/$skill/publish-from-bot" \
            -H "$METABOT_AUTH" -H "Content-Type: application/json" \
            -d "{\"botName\":\"$bot\"}" | _json
          ;;
        install|i)
          local skill="${1:-}" bot="${2:-}"
          if [[ -z "$skill" || -z "$bot" ]]; then
            echo "Usage: metabot bot-skills install <skillName> <botName>"
            exit 1
          fi
          local source="${3:-local}"
          python3 -c "
import json, sys
print(json.dumps({'botName': sys.argv[1], 'source': sys.argv[2]}))
" "$bot" "$source" | \
          curl -s -X POST "$METABOT_URL/api/skills/$skill/install" \
            -H "$METABOT_AUTH" -H "Content-Type: application/json" \
            -d @- | _json
          ;;
        remove|rm)
          if [[ -z "${1:-}" ]]; then echo "Usage: metabot bot-skills remove <name>"; exit 1; fi
          curl -s -X DELETE "$METABOT_URL/api/skills/$1" -H "$METABOT_AUTH" | _json
          ;;
        *)
          echo "metabot bot-skills - Per-bot Skill Hub (bridge-local skill registry)"
          echo "  metabot bot-skills list                               - List all skills (local + peer)"
          echo "  metabot bot-skills search <query>                     - Search skills by keyword"
          echo "  metabot bot-skills get <name>                         - Get skill details"
          echo "  metabot bot-skills publish <botName> <skillName>      - Publish a bot's skill to the hub"
          echo "  metabot bot-skills install <skillName> <botName>      - Install a skill to a bot"
          echo "  metabot bot-skills remove <name>                      - Unpublish a skill"
          ;;
      esac
      ;;
    health|h)
      curl -s -H "$METABOT_AUTH" "$METABOT_URL/api/health" | _json
      ;;
  esac
}

print_help() {
  echo -e "${BOLD}metabot${NC} - MetaBot CLI"
  echo ""
  echo "  Process control:"
  echo "    metabot update     Pull latest, rebuild, and restart"
  echo "    metabot start      Start MetaBot with PM2"
  echo "    metabot stop       Stop MetaBot"
  echo "    metabot restart    Restart MetaBot"
  echo "    metabot logs       View live logs (pass -n 100 etc.)"
  echo "    metabot status     Show PM2 process status"
  echo ""
  echo "  Bridge daemon API (localhost:9100):"
  echo "    metabot bots                       List all bots (local + peer)"
  echo "    metabot bot <name>                 Get bot details"
  echo "    metabot talk <bot> <chatId> <msg>  Talk to a bot (bridge /api/talk)"
  echo "    metabot schedule …                 Task scheduling (list/add/cron/pause/resume/cancel)"
  echo "    metabot peers                      List peers and their status"
  echo "    metabot stats                      Cost & usage stats"
  echo "    metabot metrics                    Prometheus metrics"
  echo "    metabot voice …                    RTC voice call + TTS (call/transcript/list/config/tts)"
  echo "    metabot bot-skills …               Per-bot Skill Hub (list/search/get/publish/install/remove)"
  echo "    metabot health                     Health check"
  echo ""
  echo "  Feature subcommands (delegated to metabot-core):"
  echo "    metabot t5t … | agents … | memory … | skills …"
}

case "${1:-}" in
  update|up)    cmd_update ;;
  start)        cmd_start ;;
  stop)         cmd_stop ;;
  restart|rs)   cmd_restart ;;
  logs|log)     shift; cmd_logs "$@" ;;
  status|st)    cmd_status ;;
  bots|b|bot|talk|t|schedule|sched|sc|peers|p|stats|metrics|m|voice|v|bot-skills|health|h)
                cmd_bridge_api "$@" ;;
  ""|help|--help|-h) print_help ;;
  *)            cmd_delegate "$@" ;;
esac
