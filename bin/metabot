check("voice_defaults", voice_ok, "voice_defaults_missing" if not voice_ok else "ok",
      "Voice/TTS defaults appear configured." if voice_ok else "No voice/TTS defaults found.",
      "Install package default env or configure VOLCENGINE_TTS_* / OPENAI_API_KEY and bot voiceReply.",
      False,
