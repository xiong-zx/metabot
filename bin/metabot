voice_default = {
    "defaultOn": env("METABOT_VOICE_REPLY_DEFAULT_ON"),
    "provider": env("METABOT_VOICE_REPLY_PROVIDER") or env("FEISHU_VOICE_REPLY_PROVIDER"),
    "hasVolcengineAppId": bool(env("VOLCENGINE_TTS_APPID")),
