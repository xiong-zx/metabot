#!/usr/bin/env bash
# metabot - MetaBot CLI (single binary)
# Three command categories:
#   1. Bridge process control: update | start | stop | restart | logs | status
#   2. Bridge daemon API (localhost:9100): bots | bot | talk | schedule |
#      peers | stats | metrics | voice | health
#   3. metabot-core delegation: t5t | agents | memory | skills

set -euo pipefail

# Resolve METABOT_HOME: env var > script's parent dir (follows symlinks) > $HOME/metabot
if [[ -z "${METABOT_HOME:-}" ]]; then
  _src="${BASH_SOURCE[0]}"
  if command -v readlink &>/dev/null; then
    _src="$(readlink -f "$_src" 2>/dev/null || echo "$_src")"
  fi
  _sd="$(cd "$(dirname "$_src")/.." 2>/dev/null && pwd)" || _sd=""
  if [[ -n "$_sd" && -d "$_sd/.git" && -f "$_sd/package.json" ]]; then
    METABOT_HOME="$_sd"
  else
    METABOT_HOME="$HOME/metabot"
  fi
fi

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

info()    { echo -e "${BLUE}[INFO]${NC} $*"; }
success() { echo -e "${GREEN}[OK]${NC} $*"; }
warn()    { echo -e "${YELLOW}[WARN]${NC} $*"; }
error()   { echo -e "${RED}[ERROR]${NC} $*"; }

# --- Bridge daemon API config (Category 2): env vars > .env file > defaults ---
# Read API_PORT / API_SECRET / METABOT_URL from $METABOT_HOME/.env without
# clobbering values already exported in the environment.
_load_bridge_api_config() {
  local envf="$METABOT_HOME/.env"
  if [[ -f "$envf" ]]; then
    _api_port=$(sed -n 's/^API_PORT=//p' "$envf" 2>/dev/null || true)
    _api_secret=$(sed -n 's/^API_SECRET=//p' "$envf" 2>/dev/null || true)
    _api_url=$(sed -n 's/^METABOT_URL=//p' "$envf" 2>/dev/null || true)
  fi
  METABOT_URL="${METABOT_URL:-${_api_url:-http://localhost:${_api_port:-9100}}}"
  _api_secret="${API_SECRET:-${_api_secret:-changeme}}"
  METABOT_AUTH="Authorization: Bearer $_api_secret"
}

_json() { python3 -m json.tool 2>/dev/null || cat; }

cmd_update() {
  local update_source="${METABOT_UPDATE_SOURCE:-package}"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --git)
        update_source="git"
        shift
        ;;
      --package|--tarball)
        update_source="package"
        shift
        ;;
      *)
        error "Unknown update option: $1"
        echo "  Usage: metabot update [--package|--git]"
        exit 1
        ;;
    esac
  done

  if [[ "$update_source" != "git" ]]; then
    # Company-default refresh path: re-run the metabot-core bootstrap, which
    # downloads /install/latest.tgz and overlays the bot-host runtime. This is
    # intentionally used even when .git exists, so GitHub/GitLab credentials are
    # not part of the normal user update story. Developers can opt into the old
    # source checkout workflow with `metabot update --git`.
    if [[ -f "$METABOT_HOME/install.sh" || -d "$METABOT_HOME" ]]; then
      local core_url="${METABOT_CORE_URL:-http://localhost:9200}"
      info "Refreshing MetaBot from internal package at $core_url/install/latest.tgz"
      exec bash -c 'curl -fsSL "$1/install/install.sh" | METABOT_HOME="$2" bash' bash "$core_url" "$METABOT_HOME"
    fi
    error "MetaBot not found at $METABOT_HOME"
    echo "  Run the installer first:"
    echo "    curl -fsSL http://localhost:9200/install/install.sh | bash"
    exit 1
  fi

  if [[ ! -d "$METABOT_HOME/.git" ]]; then
    error "Git update requested, but $METABOT_HOME is not a git checkout."
    echo "  Use the default package refresh instead:"
    echo "    metabot update"
    exit 1
  fi

  # Always re-exec from the repo copy before doing anything.
  # This prevents the running script (e.g. ~/.local/bin/metabot) from being
  # overwritten mid-execution when we copy CLI tools later.
  if [[ -z "${METABOT_REEXEC:-}" ]] && [[ -f "$METABOT_HOME/bin/metabot" ]]; then
    export METABOT_REEXEC=1
    exec "$METABOT_HOME/bin/metabot" update --git
  fi

  info "Pulling latest code..."
  cd "$METABOT_HOME"
  local old_head
  old_head="$(git rev-parse HEAD)"
  git pull --ff-only || { error "git pull failed"; exit 1; }

  # Re-exec if git pull updated this script (the repo copy we're running from)
  if ! git diff --quiet "$old_head" HEAD -- bin/metabot 2>/dev/null; then
    info "metabot CLI updated, re-launching with new version..."
    exec "$METABOT_HOME/bin/metabot" update --git
  fi

  info "Installing dependencies..."
  npm install --production=false

  info "Building..."
  npm run build

  # Update CLI tools in ~/.local/bin.
  # `metabot` is the sole dispatcher (bridge process control + delegate to
  # metabot-core feature CLI). `mb`/`mm`/`mh`/`mbcore` are legacy and stay removed.
  LOCAL_BIN="$HOME/.local/bin"
  if [[ -d "$LOCAL_BIN" ]]; then
    info "Updating CLI tools..."
    for cli in metabot; do
      local src="$METABOT_HOME/bin/$cli"
      local dst="$LOCAL_BIN/$cli"
      if [[ -f "$src" ]]; then
        # Skip when $dst already points at $src — copying a file onto its own
        # symlink target errors out with `cp: 'a' and 'b' are the same file`.
        if [[ "$src" -ef "$dst" ]]; then
          continue
        fi
        cp "$src" "$dst"
        chmod +x "$dst"
      fi
    done
    # Clean up legacy CLIs (Phase 4 consolidation + temp shims).
    for legacy_cli in mb mm mh mbcore fd; do
      if [[ -f "$LOCAL_BIN/$legacy_cli" || -L "$LOCAL_BIN/$legacy_cli" ]]; then
        rm -f "$LOCAL_BIN/$legacy_cli"
      fi
    done
    success "CLI tools updated"
  fi

  # Update skills in ~/.claude/skills and ~/.codex/skills
  SKILLS_DIR="$HOME/.claude/skills"
  CODEX_SKILLS_DIR="$HOME/.codex/skills"
  AGENTS_SKILLS_DIR="$HOME/.agents/skills"
  mkdir -p "$SKILLS_DIR" "$CODEX_SKILLS_DIR"
  info "Updating skills..."
  local src=""
  local -a lark_skill_names=(
    lark-base
    lark-calendar
    lark-contact
    lark-doc
    lark-drive
    lark-event
    lark-im
    lark-mail
    lark-minutes
    lark-openapi-explorer
    lark-shared
    lark-sheets
    lark-skill-maker
    lark-task
    lark-vc
    lark-whiteboard
    lark-wiki
    lark-workflow-meeting-summary
    lark-workflow-standup-report
  )
  # Phase 4 consolidation: `metamemory` and `skill-hub` skill bundles are
  # subsumed by the unified `metabot` skill (which delegates memory/skills/
  # agents/t5t to the metabot-core feature CLI). metabot-team is the compact
  # Agent Teams coordination skill. metaskill / metaschedule remain opt-in;
  # sources still ship in src/skills/* for manual copy.
  for skill in metabot voice metabot-team; do
    case "$skill" in
      metabot)      src="$METABOT_HOME/packages/skills/metabot" ;;
      voice)        src="$METABOT_HOME/src/skills/voice" ;;
      metabot-team) src="$METABOT_HOME/src/skills/metabot-team" ;;
      *)            src="" ;;
    esac
    if [[ -n "$src" && -d "$src" ]]; then
      for dst_root in "$SKILLS_DIR" "$CODEX_SKILLS_DIR"; do
        mkdir -p "$dst_root/$skill"
        cp -r "$src/." "$dst_root/$skill/"
      done
    fi
  done
  # Strip legacy skill bundles (Phase 4 consolidation).
  for legacy in metamemory skill-hub; do
    for dst_root in "$SKILLS_DIR" "$CODEX_SKILLS_DIR"; do
      if [[ -d "$dst_root/$legacy" ]]; then
        rm -rf "$dst_root/$legacy"
        info "Removed legacy $legacy skill from $dst_root (use \`metabot ${legacy/skill-hub/skills}\` instead)"
      fi
    done
  done
  # Clean up legacy feishu-doc skill
  if [[ -d "$SKILLS_DIR/feishu-doc" ]]; then
    rm -rf "$SKILLS_DIR/feishu-doc"
    info "Removed legacy feishu-doc skill"
  fi
  if [[ -d "$CODEX_SKILLS_DIR/feishu-doc" ]]; then
    rm -rf "$CODEX_SKILLS_DIR/feishu-doc"
  fi
  # Clean up legacy metaskill — now opt-in. Override with KEEP_METASKILL=1.
  if [[ -d "$SKILLS_DIR/metaskill" ]] && [[ "${KEEP_METASKILL:-}" != "1" ]]; then
    rm -rf "$SKILLS_DIR/metaskill"
    info "Removed legacy metaskill (opt-in — set KEEP_METASKILL=1 to keep)"
  fi
  if [[ -d "$CODEX_SKILLS_DIR/metaskill" ]] && [[ "${KEEP_METASKILL:-}" != "1" ]]; then
    rm -rf "$CODEX_SKILLS_DIR/metaskill"
  fi

  # Update lark-cli and its AI Agent skills only if previously installed.
  # New installs still opt in via install.sh; updates keep existing setups fresh.
  local has_lark_skills=false
  local skill_root
  for skill_root in "$AGENTS_SKILLS_DIR" "$SKILLS_DIR" "$CODEX_SKILLS_DIR"; do
    if [[ -d "$skill_root/lark-doc" ]]; then
      has_lark_skills=true
      break
    fi
  done
  if command -v lark-cli &>/dev/null; then
    info "Updating lark-cli..."
    if npm install -g @larksuite/cli@latest 2>/dev/null || npm install -g --prefix "$HOME/.local" @larksuite/cli@latest 2>/dev/null; then
      success "lark-cli updated ($(lark-cli --version 2>/dev/null || echo 'version unknown'))"
    else
      warn "lark-cli update failed; MetaBot update will continue"
    fi
    has_lark_skills=true
  fi
  if [[ "$has_lark_skills" == "true" ]]; then
    info "Updating lark-cli AI Agent skills..."
    if npx skills add larksuite/cli --all -y -g 2>/dev/null; then
      success "lark-cli AI Agent skills updated"
    else
      warn "lark-cli skills update failed; keeping existing installed copies"
    fi
    # Mirror lark-cli skills into Claude/Codex skill roots. Recent lark-cli
    # installs use ~/.agents/skills, while older installs may use ~/.claude.
    local lark_skill
    for lark_skill in "${lark_skill_names[@]}"; do
      local lark_src=""
      for skill_root in "$AGENTS_SKILLS_DIR" "$SKILLS_DIR" "$CODEX_SKILLS_DIR"; do
        if [[ -d "$skill_root/$lark_skill" ]]; then
          lark_src="$skill_root/$lark_skill"
          break
        fi
      done
      if [[ -n "$lark_src" ]]; then
        for dst_root in "$SKILLS_DIR" "$CODEX_SKILLS_DIR"; do
          mkdir -p "$dst_root/$lark_skill"
          # Skip when src and dst already resolve to the same inode
          # (lark-cli installs ~/.agents/skills/* and symlinks them into
          # ~/.claude/skills + ~/.codex/skills — cp would error on same-file).
          [[ "$lark_src" -ef "$dst_root/$lark_skill" ]] && continue
          if [[ "$lark_src" != "$dst_root/$lark_skill" ]]; then
            cp -r "$lark_src/." "$dst_root/$lark_skill/"
          fi
        done
      fi
    done
  fi
  success "Skills updated"

  # Update workspace skills if bots.json exists
  if [[ -f "$METABOT_HOME/bots.json" ]] && command -v node &>/dev/null; then
    local work_dir
    work_dir=$(node -e "
      const c=JSON.parse(require('fs').readFileSync('$METABOT_HOME/bots.json','utf-8'));
      const b=[...(c.feishuBots||[]),...(c.telegramBots||[]),...(c.wechatBots||[])];
      if(b[0])console.log(b[0].defaultWorkingDirectory);
    " 2>/dev/null || true)
    if [[ -n "$work_dir" ]]; then
      local ws_skills_dir="$work_dir/.claude/skills"
      local ws_codex_skills_dir="$work_dir/.codex/skills"
      mkdir -p "$ws_skills_dir" "$ws_codex_skills_dir"

      # Copy common skills (Phase 4: metamemory/skill-hub removed).
      for skill in metabot voice; do
        if [[ -d "$SKILLS_DIR/$skill" ]]; then
          for dst_root in "$ws_skills_dir" "$ws_codex_skills_dir"; do
            mkdir -p "$dst_root/$skill"
            cp -r "$SKILLS_DIR/$skill/." "$dst_root/$skill/"
          done
        fi
      done
      # Strip legacy skill bundles from a previously-deployed workspace.
      for legacy in metamemory skill-hub; do
        for dst_root in "$ws_skills_dir" "$ws_codex_skills_dir"; do
          if [[ -d "$dst_root/$legacy" ]]; then
            rm -rf "$dst_root/$legacy"
          fi
        done
      done
      # Mirror opt-in skills (metaskill / metaschedule) only when present.
      for skill in metaskill metaschedule; do
        if [[ -d "$SKILLS_DIR/$skill" ]]; then
          for dst_root in "$ws_skills_dir" "$ws_codex_skills_dir"; do
            mkdir -p "$dst_root/$skill"
            cp -r "$SKILLS_DIR/$skill/." "$dst_root/$skill/"
          done
        fi
      done
      # Copy lark-cli skills if previously installed
      if [[ "$has_lark_skills" == "true" ]]; then
        local lark_skill
        for lark_skill in "${lark_skill_names[@]}"; do
          local lark_src=""
          for skill_root in "$AGENTS_SKILLS_DIR" "$SKILLS_DIR" "$CODEX_SKILLS_DIR"; do
            if [[ -d "$skill_root/$lark_skill" ]]; then
              lark_src="$skill_root/$lark_skill"
              break
            fi
          done
          if [[ -n "$lark_src" ]]; then
            for dst_root in "$ws_skills_dir" "$ws_codex_skills_dir"; do
              mkdir -p "$dst_root/$lark_skill"
              [[ "$lark_src" -ef "$dst_root/$lark_skill" ]] && continue
              cp -r "$lark_src/." "$dst_root/$lark_skill/"
            done
          fi
        done
      fi
      # Clean up legacy feishu-doc in workspace
      if [[ -d "$ws_skills_dir/feishu-doc" ]]; then
        rm -rf "$ws_skills_dir/feishu-doc"
      fi
      if [[ -d "$ws_codex_skills_dir/feishu-doc" ]]; then
        rm -rf "$ws_codex_skills_dir/feishu-doc"
      fi
      # Update CLAUDE.md
      if [[ -f "$METABOT_HOME/src/workspace/CLAUDE.md" ]]; then
        cp "$METABOT_HOME/src/workspace/CLAUDE.md" "$work_dir/CLAUDE.md"
        if [[ ! -e "$work_dir/AGENTS.md" ]]; then
          cp "$METABOT_HOME/src/workspace/CLAUDE.md" "$work_dir/AGENTS.md"
        fi
      fi
      success "Workspace skills updated"
    fi
  fi

  _update_core_workspace || true

  info "Restarting MetaBot..."
  cmd_restart --source update --reason "metabot update" --resume
}

# Optimization: if a sibling metabot-core checkout exists, pull + build it so
# the delegated feature CLI (`metabot t5t/agents/memory/skills`) stays in sync
# with the central server. Best-effort — failures don't break the bridge update.
_update_core_workspace() {
  local core_dir="$METABOT_HOME/../metabot-workspace/metabot-core"
  if [[ ! -d "$core_dir/.git" || ! -f "$core_dir/package.json" ]]; then
    return 0
  fi
  echo ""
  info "Updating sibling metabot-core workspace at $core_dir ..."
  (
    cd "$core_dir"
    if ! git pull --ff-only; then
      warn "metabot-core: git pull --ff-only failed (uncommitted changes?). Skipping build."
      exit 1
    fi
    info "metabot-core: installing dependencies..."
    npm install --include=dev --silent || {
      warn "metabot-core: npm install failed."
      exit 1
    }
    info "metabot-core: building..."
    npm run build || {
      warn "metabot-core: build failed."
      exit 1
    }
  ) && success "metabot-core workspace updated" || warn "metabot-core workspace update incomplete (feature CLI may be stale)"
}

_restart_state_dir() {
  if [[ -n "${SESSION_STORE_DIR:-}" ]]; then
    printf '%s\n' "$SESSION_STORE_DIR"
    return
  fi
  local configured=""
  if [[ -f "$METABOT_HOME/.env" ]]; then
    configured="$(sed -n 's/^SESSION_STORE_DIR=//p' "$METABOT_HOME/.env" 2>/dev/null | tail -1)"
    configured="${configured%\"}"; configured="${configured#\"}"
    configured="${configured%\'}"; configured="${configured#\'}"
  fi
  if [[ -n "$configured" ]]; then
    configured="${configured/#\~/$HOME}"
    printf '%s\n' "$configured"
  else
    printf '%s\n' "$HOME/.metabot"
  fi
}

# Drop a breadcrumb so the bridge knows it was just restarted. After
# `pm2 restart` the node process (and every Claude session) is killed and
# respawned, so the agent that issued the restart loses all memory of having
# done so — without this it sees "please restart" in resumed history and
# restarts again in a loop. The bridge reads this file at boot, injects a
# one-shot reminder, and deletes it only after startup health and recovery.
_write_restart_breadcrumb() {
  local dir
  dir="$(_restart_state_dir)"
  mkdir -p "$dir" 2>/dev/null || return 0
  python3 - "$dir/last-restart.json" <<'PY' 2>/dev/null || true
import json
import os
import sys
import time

data = {"restartedAt": int(time.time())}
fields = {
    "METABOT_BOT_NAME": "botName",
    "METABOT_CHAT_ID": "chatId",
    "METABOT_RESTART_REASON": "reason",
    "METABOT_RESTART_SOURCE": "source",
    "METABOT_RESTART_REQUEST_ID": "requestId",
}
for env_name, json_name in fields.items():
    value = os.environ.get(env_name, "").strip()
    if value:
        data[json_name] = value

resume = os.environ.get("METABOT_RESTART_RESUME", "").strip().lower()
if resume in ("0", "false", "no", "off"):
    data["resume"] = False
elif resume in ("1", "true", "yes", "on"):
    data["resume"] = True

with open(sys.argv[1], "w", encoding="utf-8") as f:
    json.dump(data, f, ensure_ascii=False)
    f.write("\n")
PY
}

_new_restart_request_id() {
  python3 - <<'PY'
import time
import uuid
print(f"restart-{int(time.time() * 1000)}-{str(uuid.uuid4())[:8]}")
PY
}

# Atomically claim one restart attempt for a requestId. This small standalone
# state update must run before contacting PM2 because the current process tree
# can disappear as soon as the daemon accepts the restart.
_claim_restart_request() {
  local request_id="$1"
  local dir
  dir="$(_restart_state_dir)"
  mkdir -p "$dir"
  python3 - "$dir/restart-requests.json" "$request_id" "${METABOT_BOT_NAME:-cli}" "${METABOT_CHAT_ID:-cli}" "${METABOT_RESTART_REASON:-cli restart}" "${METABOT_RESTART_SOURCE:-cli}" "$METABOT_HOME" "$METABOT_HOME/src/index.ts" <<'PY'
import fcntl
import json
import os
import sys
import time

path, request_id, bot, chat, reason, source, cwd, script = sys.argv[1:]
lock_path = f"{path}.lock"
now = int(time.time() * 1000)
os.makedirs(os.path.dirname(path), exist_ok=True)
with open(lock_path, "a+", encoding="utf-8") as lock:
    fcntl.flock(lock, fcntl.LOCK_EX)
    try:
        with open(path, "r", encoding="utf-8") as src:
            rows = json.load(src)
        if not isinstance(rows, list):
            rows = []
    except Exception:
        rows = []
    record = next((row for row in rows if row.get("requestId") == request_id), None)
    if record and (int(record.get("attemptCount") or 0) >= 1 or record.get("status") in ("restarting", "healthy", "failed")):
        print("duplicate")
        raise SystemExit(0)
    if record is None:
        record = {
            "requestId": request_id,
            "requesterBotName": bot,
            "requesterChatId": chat,
            "userId": os.environ.get("METABOT_RESTART_USER_ID", "cli"),
            "reason": reason,
            "force": False,
            "status": "scheduled",
            "blockers": [],
            "readiness": [],
            "createdAt": now,
            "updatedAt": now,
            "scheduledAt": now,
        }
        rows.append(record)
    record.update({
        "status": "restarting",
        "attemptCount": int(record.get("attemptCount") or 0) + 1,
        "attemptedAt": record.get("attemptedAt") or now,
        "updatedAt": now,
        "targetCwd": os.path.realpath(cwd),
        "targetScript": os.path.realpath(script),
        "source": source,
    })
    tmp = f"{path}.{os.getpid()}.tmp"
    with open(tmp, "w", encoding="utf-8") as dst:
        json.dump(rows, dst, ensure_ascii=False, indent=2)
        dst.write("\n")
    os.replace(tmp, path)
    print("claimed")
PY
}

_mark_restart_request_failed() {
  local request_id="$1"
  local failure="$2"
  local dir
  dir="$(_restart_state_dir)"
  python3 - "$dir/restart-requests.json" "$request_id" "$failure" <<'PY' 2>/dev/null || true
import fcntl
import json
import os
import sys
import time

path, request_id, failure = sys.argv[1:]
with open(f"{path}.lock", "a+", encoding="utf-8") as lock:
    fcntl.flock(lock, fcntl.LOCK_EX)
    try:
        with open(path, "r", encoding="utf-8") as src:
            rows = json.load(src)
    except Exception:
        rows = []
    now = int(time.time() * 1000)
    for row in rows:
        if row.get("requestId") == request_id:
            row.update({"status": "failed", "failedAt": row.get("failedAt") or now, "updatedAt": now, "healthError": failure[:1000]})
            break
    tmp = f"{path}.{os.getpid()}.tmp"
    with open(tmp, "w", encoding="utf-8") as dst:
        json.dump(rows, dst, ensure_ascii=False, indent=2)
        dst.write("\n")
    os.replace(tmp, path)
PY
}

_pm2_metabot_runtime() {
  pm2 jlist 2>/dev/null | python3 -c '
import json, sys
try: rows=json.load(sys.stdin)
except Exception: rows=[]
app=next((row for row in rows if row.get("name") == "metabot"), None)
if app:
    env=app.get("pm2_env") or {}
    print("\t".join([str(env.get("pm_cwd") or ""), str(env.get("pm_exec_path") or ""), str(app.get("pid") or "")]))
'
}

_is_metabot_descendant() {
  local runtime pid metabot_pid
  runtime="$(_pm2_metabot_runtime || true)"
  metabot_pid="$(printf '%s' "$runtime" | awk -F '\t' '{print $3}')"
  [[ "$metabot_pid" =~ ^[0-9]+$ ]] || return 1
  pid="$$"
  while [[ "$pid" =~ ^[0-9]+$ && "$pid" -gt 1 ]]; do
    [[ "$pid" == "$metabot_pid" ]] && return 0
    pid="$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ' || true)"
  done
  return 1
}

_wait_restart_terminal_state() {
  local request_id="$1"
  local timeout="${2:-60}"
  local dir
  dir="$(_restart_state_dir)"
  local i state
  for ((i=0; i<timeout; i++)); do
    state="$(python3 - "$dir/restart-requests.json" "$request_id" <<'PY' 2>/dev/null || true
import json, sys
try:
    rows=json.load(open(sys.argv[1], encoding="utf-8"))
except Exception:
    rows=[]
row=next((row for row in rows if row.get("requestId") == sys.argv[2]), {})
print(row.get("status", ""))
PY
)"
    [[ "$state" == "healthy" ]] && return 0
    [[ "$state" == "failed" ]] && return 1
    sleep 1
  done
  return 1
}

_wait_bridge_health() {
  local timeout="${1:-60}"
  _load_bridge_api_config
  local url="${METABOT_URL%/}/api/health"
  local i
  for ((i=0; i<timeout; i++)); do
    if command -v curl >/dev/null 2>&1 && curl -fsS --connect-timeout 1 --max-time 2 -H "$METABOT_AUTH" "$url" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done
  return 1
}

cmd_start() {
  pm2 start "$METABOT_HOME/ecosystem.config.cjs" --only metabot --update-env
  if _wait_bridge_health 60; then
    pm2 save --force
  else
    error "MetaBot did not become healthy; PM2 process list was not saved."
    return 1
  fi
}
cmd_stop()    { pm2 stop metabot; }
cmd_restart() {
  local wait=false
  local json=false
  local wait_timeout=60
  local reason=""
  local bot_name=""
  local chat_id=""
  local source=""
  local request_id=""
  local resume=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --wait) wait=true; shift ;;
      --json) json=true; shift ;;
      --timeout)
        if [[ $# -lt 2 || "${2:-}" == --* ]]; then warn "--timeout requires seconds"; return 2; fi
        wait_timeout="$2"; shift 2
        ;;
      --reason)
        if [[ $# -lt 2 ]]; then warn "--reason requires text"; return 2; fi
        reason="$2"; shift 2
        ;;
      --bot|--bot-name)
        if [[ $# -lt 2 || "${2:-}" == --* ]]; then warn "$1 requires a bot name"; return 2; fi
        bot_name="$2"; shift 2
        ;;
      --chat|--chat-id)
        if [[ $# -lt 2 || "${2:-}" == --* ]]; then warn "$1 requires a chat id"; return 2; fi
        chat_id="$2"; shift 2
        ;;
      --source)
        if [[ $# -lt 2 || "${2:-}" == --* ]]; then warn "--source requires a value"; return 2; fi
        source="$2"; shift 2
        ;;
      --request-id)
        if [[ $# -lt 2 || "${2:-}" == --* ]]; then warn "--request-id requires a value"; return 2; fi
        request_id="$2"; shift 2
        ;;
      --resume) resume="1"; shift ;;
      --no-resume) resume="0"; shift ;;
      --help|-h)
        echo "Usage: metabot restart [--wait] [--json] [--timeout SEC] [--reason TEXT] [--bot NAME] [--chat ID] [--source SOURCE] [--resume|--no-resume]"
        return 0
        ;;
      *)
        warn "Unknown restart option: $1"
        return 2
        ;;
    esac
  done

  if ! [[ "$wait_timeout" =~ ^[0-9]+$ ]] || [[ "$wait_timeout" -lt 1 ]]; then
    warn "--timeout must be a positive integer"
    return 2
  fi

  [[ -n "$bot_name" ]] && export METABOT_BOT_NAME="$bot_name"
  [[ -n "$chat_id" ]] && export METABOT_CHAT_ID="$chat_id"
  [[ -n "$reason" ]] && export METABOT_RESTART_REASON="$reason"
  [[ -n "$source" ]] && export METABOT_RESTART_SOURCE="$source"
  request_id="${request_id:-$(_new_restart_request_id)}"
  export METABOT_RESTART_REQUEST_ID="$request_id"
  [[ -n "$resume" ]] && export METABOT_RESTART_RESUME="$resume"

  local runtime current_cwd current_script
  runtime="$(_pm2_metabot_runtime || true)"
  current_cwd="$(printf '%s' "$runtime" | awk -F '\t' '{print $1}')"
  current_script="$(printf '%s' "$runtime" | awk -F '\t' '{print $2}')"
  if [[ -n "$current_cwd" && "$(readlink -f "$current_cwd")" != "$(readlink -f "$METABOT_HOME")" ]]; then
    error "Refusing to switch the live runtime from inside 'metabot restart'."
    echo "  Current cwd: $current_cwd"
    echo "  Requested cwd: $METABOT_HOME"
    echo "  Use 'metabot deploy-runtime --runtime $METABOT_HOME' from SSH or another controller outside the MetaBot process tree."
    return 2
  fi

  local claim
  claim="$(_claim_restart_request "$request_id")"
  if [[ "$claim" == "duplicate" ]]; then
    [[ "$json" == true ]] && printf '{"ok":true,"duplicate":true,"requestId":"%s"}\n' "$request_id"
    info "Restart request $request_id was already attempted; no second restart was issued."
    return 0
  fi

  _write_restart_breadcrumb
  local restart_ok=true
  if [[ -n "$current_cwd" ]]; then
    pm2 restart metabot --update-env || restart_ok=false
  else
    pm2 start "$METABOT_HOME/ecosystem.config.cjs" --only metabot --update-env || restart_ok=false
  fi

  local health_ok=true
  if [[ "$wait" == true ]]; then
    _wait_bridge_health "$wait_timeout" || health_ok=false
    [[ "$health_ok" == true ]] && _wait_restart_terminal_state "$request_id" "$wait_timeout" || health_ok=false
  fi

  if [[ "$restart_ok" != true ]]; then
    _mark_restart_request_failed "$request_id" "PM2 rejected the atomic restart request"
  elif [[ "$wait" == true && "$health_ok" != true ]]; then
    _mark_restart_request_failed "$request_id" "Restart did not reach healthy state within ${wait_timeout}s"
  fi

  if [[ "$json" == true ]]; then
    printf '{"ok":%s,"healthOk":%s,"wait":%s,"timeout":%s,"requestId":"%s"}\n' \
      "$([[ "$restart_ok" == true ]] && echo true || echo false)" \
      "$([[ "$health_ok" == true ]] && echo true || echo false)" \
      "$wait" \
      "$wait_timeout" \
      "$request_id"
  fi

  [[ "$restart_ok" == true && "$health_ok" == true ]]
}

cmd_deploy_runtime() {
  local target=""
  local wait_timeout=90
  local reason="runtime deployment"
  local json=false
  local request_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --runtime) target="${2:-}"; shift 2 ;;
      --timeout) wait_timeout="${2:-}"; shift 2 ;;
      --reason) reason="${2:-}"; shift 2 ;;
      --request-id) request_id="${2:-}"; shift 2 ;;
      --json) json=true; shift ;;
      --help|-h)
        echo "Usage: metabot deploy-runtime --runtime DIR [--timeout SEC] [--reason TEXT] [--request-id ID] [--json]"
        echo "This command must run outside the MetaBot process tree (for example from SSH)."
        return 0
        ;;
      *) error "Unknown deploy-runtime option: $1"; return 2 ;;
    esac
  done
  [[ -n "$target" ]] || { error "--runtime DIR is required"; return 2; }
  target="$(readlink -f "$target")"
  [[ -f "$target/ecosystem.config.cjs" ]] || { error "No ecosystem.config.cjs at $target"; return 2; }
  if _is_metabot_descendant; then
    error "Runtime switching is refused inside the MetaBot process tree."
    echo "Run this command from SSH or an independent deployment controller so a failed switch cannot kill its own recovery command."
    return 3
  fi

  METABOT_HOME="$target"
  export METABOT_HOME METABOT_RESTART_REASON="$reason" METABOT_RESTART_SOURCE="external-deploy" METABOT_RESTART_RESUME="1"
  export METABOT_RESTART_REQUEST_ID="${request_id:-$(_new_restart_request_id)}"
  local claim
  claim="$(_claim_restart_request "$METABOT_RESTART_REQUEST_ID")"
  if [[ "$claim" == "duplicate" ]]; then
    [[ "$json" == true ]] && printf '{"ok":true,"duplicate":true,"requestId":"%s","runtime":"%s"}\n' \
      "$METABOT_RESTART_REQUEST_ID" "$target"
    info "Deployment request $METABOT_RESTART_REQUEST_ID was already attempted; no second runtime switch was issued."
    return 0
  fi
  [[ "$claim" == "claimed" ]] || { error "Could not claim deployment request"; return 1; }
  _write_restart_breadcrumb

  local switch_helper="$target/scripts/pm2-atomic-runtime-switch.cjs"
  if [[ ! -f "$switch_helper" ]]; then
    _mark_restart_request_failed "$METABOT_RESTART_REQUEST_ID" "Atomic runtime switch helper is missing at $switch_helper"
    return 1
  fi
  if ! node "$switch_helper" "$target" metabot; then
    _mark_restart_request_failed "$METABOT_RESTART_REQUEST_ID" "PM2 rejected atomic runtime switch for $target"
    return 1
  fi
  local health_ok=true
  _wait_bridge_health "$wait_timeout" || health_ok=false
  [[ "$health_ok" == true ]] && _wait_restart_terminal_state "$METABOT_RESTART_REQUEST_ID" "$wait_timeout" || health_ok=false
  if [[ "$health_ok" != true ]]; then
    _mark_restart_request_failed "$METABOT_RESTART_REQUEST_ID" "Deployment did not reach healthy state within ${wait_timeout}s"
  fi
  if [[ "$json" == true ]]; then
    printf '{"ok":%s,"healthOk":%s,"requestId":"%s","runtime":"%s"}\n' \
      "$([[ "$health_ok" == true ]] && echo true || echo false)" \
      "$([[ "$health_ok" == true ]] && echo true || echo false)" \
      "$METABOT_RESTART_REQUEST_ID" "$target"
  fi
  [[ "$health_ok" == true ]]
}
cmd_logs()    { pm2 logs metabot "${@}"; }
cmd_status()  { pm2 describe metabot; }

cmd_doctor() {
  local json=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json=true; shift ;;
      --help|-h)
        echo "Usage: metabot doctor [--json]"
        echo "  Agent-native local diagnostics for runtime, PM2, package, core, bots, voice, Codex, and TeamClaude."
        exit 0
        ;;
      *)
        error "Unknown doctor option: $1"
        echo "  Usage: metabot doctor [--json]"
        exit 1
        ;;
    esac
  done

  METABOT_HOME="$METABOT_HOME" python3 - "$json" <<'PY'
import json
import os
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path

want_json = sys.argv[1] == "true"
home = Path(os.environ.get("METABOT_HOME") or str(Path.home() / "metabot")).expanduser()

def load_env(path: Path):
    env = {}
    if not path.exists():
        return env
    for raw in path.read_text(errors="ignore").splitlines():
        line = raw.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, v = line.split("=", 1)
        v = v.strip().strip('"').strip("'")
        env[k.strip()] = v
    return env

default_env_raw = os.environ.get("METABOT_DEFAULT_ENV_FILE")
default_env_path = Path(default_env_raw).expanduser() if default_env_raw else None
default_env_resolved_path = default_env_path.resolve() if default_env_path is not None and default_env_path.exists() else default_env_path
home_env_path = home / ".env"
file_env = {}
if default_env_path is not None:
    file_env.update(load_env(default_env_path))
file_env.update(load_env(home_env_path))

def env(name, default=None):
    return os.environ.get(name) or file_env.get(name) or default

def read_first_line(path: Path):
    try:
        for raw in path.read_text(errors="ignore").splitlines():
            line = raw.strip()
            if line:
                return line
    except Exception:
        return None
    return None

def run(cmd, timeout=4):
    try:
        p = subprocess.run(cmd, text=True, capture_output=True, timeout=timeout)
        return {"ok": p.returncode == 0, "code": p.returncode, "stdout": p.stdout.strip(), "stderr": p.stderr.strip()}
    except Exception as e:
        return {"ok": False, "code": None, "stdout": "", "stderr": str(e)}

def read_text(path):
    try:
        return Path(path).read_text(errors="ignore").strip()
    except Exception:
        return None

def proc_status_value(key):
    status = read_text("/proc/self/status") or ""
    prefix = f"{key}:"
    for raw in status.splitlines():
        if raw.startswith(prefix):
            return raw[len(prefix):].strip()
    return None

def http_json(url, token=None, timeout=4):
    req = urllib.request.Request(url)
    if token:
        req.add_header("Authorization", f"Bearer {token}")
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            body = resp.read(512 * 1024).decode("utf-8", errors="replace")
            try:
                parsed = json.loads(body)
            except Exception:
                parsed = None
            return {"ok": 200 <= resp.status < 300, "status": resp.status, "json": parsed, "bodyPreview": body[:300]}
    except urllib.error.HTTPError as e:
        return {"ok": False, "status": e.code, "json": None, "bodyPreview": e.read(300).decode("utf-8", errors="replace")}
    except Exception as e:
        return {"ok": False, "status": None, "json": None, "bodyPreview": str(e)}

def check(name, ok, code=None, diagnosis="", recommendedAction="", canAutoFix=False, data=None):
    severity = "ok" if ok else "warn"
    item = {
        "name": name,
        "ok": bool(ok),
        "severity": severity,
        "code": code or ("ok" if ok else "check_failed"),
        "diagnosis": diagnosis,
        "recommendedAction": recommendedAction,
        "canAutoFix": bool(canAutoFix),
    }
    if data is not None:
        item["data"] = data
    checks.append(item)

checks = []
report = {
    "ok": True,
    "schemaVersion": 1,
    "generatedAt": int(time.time()),
    "metabotHome": str(home),
    "configFiles": {
        "defaultEnv": str(default_env_path) if default_env_path is not None else None,
        "defaultEnvResolved": str(default_env_resolved_path) if default_env_resolved_path is not None else None,
        "worktreeEnv": str(home_env_path),
    },
    "checks": checks,
}

check("metabot_home", home.exists(), "metabot_home_missing" if not home.exists() else "ok",
      f"METABOT_HOME resolves to {home}", "Run the installer or set METABOT_HOME to the installed runtime.", False,
      {"path": str(home), "hasPackageJson": (home / "package.json").exists(), "hasEnv": (home / ".env").exists(), "hasBotsJson": (home / "bots.json").exists()})

manifest_paths = [home / ".metabot-package" / "manifest.json", home / ".metabot-package" / "default.env"]
manifest_data = {}
if manifest_paths[0].exists():
    try:
        manifest_data = json.loads(manifest_paths[0].read_text())
    except Exception as e:
        manifest_data = {"parseError": str(e)}
check("package_manifest", any(p.exists() for p in manifest_paths),
      "package_manifest_missing" if not any(p.exists() for p in manifest_paths) else "ok",
      "Package manifest/default env marker found." if any(p.exists() for p in manifest_paths) else "No .metabot-package manifest/default.env marker found in runtime.",
      "Package builds should include .metabot-package/manifest.json; package default env may include .metabot-package/default.env.",
      False,
      {"manifest": manifest_data, "hasDefaultEnv": manifest_paths[1].exists()})

def core_cli_probe(source, entry):
    entry = Path(entry).expanduser()
    resolved_entry = entry.resolve() if entry.exists() else entry
    artifact = None
    if resolved_entry.as_posix().endswith("/packages/cli/bin/metabot"):
        artifact = resolved_entry.parent.parent / "dist" / "index.js"
    ready = entry.is_file() and (artifact is None or artifact.is_file())
    return {
        "source": source,
        "entry": str(entry),
        "resolvedEntry": str(resolved_entry),
        "entryExists": entry.is_file(),
        "artifact": str(artifact) if artifact is not None else None,
        "artifactExists": artifact.is_file() if artifact is not None else None,
        "ready": ready,
    }

def append_core_cli_candidate(candidates, seen_entries, source, entry):
    probe = core_cli_probe(source, entry)
    dedupe_entry = probe["resolvedEntry"]
    if dedupe_entry in seen_entries:
        return
    seen_entries.add(dedupe_entry)
    candidates.append(probe)

explicit_core_cli = os.environ.get("METABOT_CORE_CLI")
core_cli_candidates = []
seen_core_cli_entries = set()
if explicit_core_cli:
    append_core_cli_candidate(core_cli_candidates, seen_core_cli_entries, "explicit", explicit_core_cli)
else:
    append_core_cli_candidate(core_cli_candidates, seen_core_cli_entries, "worktree", home / "packages/cli/bin/metabot")
    if default_env_resolved_path is not None:
        append_core_cli_candidate(
            core_cli_candidates,
            seen_core_cli_entries,
            "default_config_root",
            default_env_resolved_path.parent / "packages/cli/bin/metabot",
        )
    append_core_cli_candidate(
        core_cli_candidates,
        seen_core_cli_entries,
        "stable_checkout",
        Path.home() / "metabot/packages/cli/bin/metabot",
    )
    append_core_cli_candidate(
        core_cli_candidates,
        seen_core_cli_entries,
        "sibling_workspace",
        home / "../metabot-workspace/metabot-core/packages/cli/bin/metabot",
    )
    global_core_cli = shutil.which("metabot-core")
    if global_core_cli:
        append_core_cli_candidate(core_cli_candidates, seen_core_cli_entries, "path", global_core_cli)

selected_core_cli = next((candidate for candidate in core_cli_candidates if candidate["ready"]), None)
check("core_cli_artifact", selected_core_cli is not None,
      "core_cli_unbuilt" if selected_core_cli is None else "ok",
      f"Feature CLI is ready at {selected_core_cli['entry']}." if selected_core_cli else "No runnable feature CLI with its required dist artifact was found.",
      f"Build the worktree CLI with: cd {home} && npm ci && npm run build -w @xvirobotics/cli; or set METABOT_DEFAULT_ENV_FILE to a ready checkout's .env.",
      False,
      {
          "selected": selected_core_cli,
          "candidates": core_cli_candidates,
          "configRoot": str(default_env_resolved_path.parent) if default_env_resolved_path is not None else str(home),
          "configuredDefaultEnv": str(default_env_path) if default_env_path is not None else None,
          "resolvedDefaultEnv": str(default_env_resolved_path) if default_env_resolved_path is not None else None,
          "explicitOverride": bool(explicit_core_cli),
      })

pm2 = shutil.which("pm2")
pm2_data = {"installed": bool(pm2)}
pm2_ok = False
if pm2:
    j = run([pm2, "jlist"])
    pm2_data["jlistOk"] = j["ok"]
    if j["ok"]:
        try:
            apps = json.loads(j["stdout"] or "[]")
            app = next((a for a in apps if a.get("name") == "metabot"), None)
            if app:
                e = app.get("pm2_env", {})
                pm2_data.update({
                    "status": e.get("status"),
                    "cwd": e.get("pm_cwd"),
                    "script": e.get("pm_exec_path"),
                    "restartTime": e.get("restart_time"),
                    "unstableRestarts": e.get("unstable_restarts"),
                })
                pm2_ok = e.get("status") == "online" and str(e.get("pm_cwd")) == str(home)
        except Exception as e:
            pm2_data["parseError"] = str(e)
check("pm2_runtime", pm2_ok, "pm2_wrong_cwd_or_offline" if not pm2_ok else "ok",
      "PM2 metabot is online and running from METABOT_HOME." if pm2_ok else "PM2 metabot is missing, offline, or running from a different cwd.",
      "For the same runtime use 'metabot restart --wait'. To switch runtimes, run 'metabot deploy-runtime --runtime $METABOT_HOME' from SSH or another controller outside the MetaBot process tree. Never use delete+start from a Bot/Agent/Worker.",
      True,
      pm2_data)

api_port = env("API_PORT", "9100")
api_secret = env("API_SECRET", "changeme")
metabot_url = env("METABOT_URL", f"http://localhost:{api_port}")
bridge_health = http_json(f"{metabot_url.rstrip('/')}/api/health", api_secret)
check("bridge_health", bridge_health["ok"], "bridge_health_failed" if not bridge_health["ok"] else "ok",
      "Local bridge health endpoint is reachable." if bridge_health["ok"] else "Local bridge health endpoint is not reachable.",
      "Check PM2 status, API_PORT/API_SECRET, and logs/error.log.",
