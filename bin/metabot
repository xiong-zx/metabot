                "voiceReplyEnabled": voice.get("enabled"),
            })
    except Exception as e:
        bots_data.append({"parseError": str(e)})
bots_ok = bool(bots_data) and not any("parseError" in b for b in bots_data)
check("bots_config", bots_ok, "bots_config_missing_or_invalid" if not bots_ok else "ok",
      "bots.json parsed." if bots_ok else "bots.json missing, empty, or invalid.",
      "Create/fix bots.json or run install.sh.",
      False,
